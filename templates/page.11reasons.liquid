<script>
(function () {
  // Edit this if the product URL changes
  var PRODUCT_URL = 'https://www.frankynu.com/products/franky-protein-coffee';

  function buildCtaUrl() {
    try {
      var current = new URL(window.location.href);
      var target = new URL(PRODUCT_URL);
      current.searchParams.forEach(function (value, key) {
        if (/^(utm_|gclid|fbclid|msclkid|ttclid|campaignid|adgroupid|nb_|adname|placement|device|network|keyword|medium)/i.test(key)) {
          target.searchParams.set(key, value);
        }
      });
      return target.toString();
    } catch (e) {
      return PRODUCT_URL;
    }
  }

  function wireCtas() {
    var url = buildCtaUrl();
    document.querySelectorAll('[data-franky-cta]').forEach(function (el) {
      el.setAttribute('href', url);
    });
  }

  function startCountdown() {
    var el = document.getElementById('frankyTimer');
    if (!el) return;
    var KEY = 'franky_lp_deadline';
    var deadline = parseInt(localStorage.getItem(KEY) || '0', 10);
    var now = Date.now();
    if (!deadline || deadline < now) {
      deadline = now + 24 * 60 * 60 * 1000;
      try { localStorage.setItem(KEY, String(deadline)); } catch (e) {}
    }
    function tick() {
      var diff = Math.max(0, deadline - Date.now());
      var h = Math.floor(diff / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      el.textContent = (h < 10 ? '0' : '') + h + ':' + (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
    }
    tick();
    setInterval(tick, 1000);
  }

  function wireStickyBar() {
    var bar = document.getElementById('frankyStickyBar');
    if (!bar) return;
    function onScroll() {
      if (window.scrollY > 600) bar.classList.add('visible');
      else bar.classList.remove('visible');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { wireCtas(); startCountdown(); wireStickyBar(); });
  } else {
    wireCtas(); startCountdown(); wireStickyBar();
  }
})();
</script>
