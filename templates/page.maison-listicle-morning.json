        },
        "faq_item_LrfjAk": {
          "type": "faq_item",
          "settings": {
            "question": "How much caffeine?",
            "answer": "<p>Each serving contains about <strong>90–100mg of caffeine</strong>, roughly the same as a standard cup of coffee.</p>"
          }
        },
        "faq_item_M64qLL": {
          "type": "faq_item",
          "settings": {
            "question": "Will I crash?",
            "answer": "<p>No. Franky is formulated to provide <strong>smooth, sustained energy</strong> without the sudden spikes and crashes often associated with traditional coffee.</p>"
          }
        },
        "faq_item_H3fBjn": {
          "type": "faq_item",
          "settings": {
            "question": "Can I replace breakfast?",
            "answer": "<p>Franky can be used as a <strong>light breakfast option</strong> or alongside your morning routine, but it’s not intended to fully replace a balanced meal.</p>"
          }
        },
        "faq_item_C4bGCH": {
          "type": "faq_item",
          "settings": {
            "question": "Is it dairy-free?",
            "answer": "<p>Yes. Franky is <strong>dairy-free</strong> and designed to be easy to digest.</p>"
          }
        },
