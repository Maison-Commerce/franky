          "type": "faq_item",
          "settings": {
            "question": "Can I cancel my subscription?",
            "answer": "<p>Yes — anytime, in two clicks from your account → Subscriptions. No fees, no contract, no cancellation form. Need a break instead? Skip an order or change the cadence from the same page.</p>"
          }
        }
