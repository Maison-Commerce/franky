        "faq_item_XNiLT6": {
          "type": "faq_item",
          "settings": {
            "question": "How does your guarantee work?",
            "answer": "<p>90 days. Drink the entire bag. All 30 servings. If you don't feel the difference, email us. We refund you. No return shipping required. No photos of your empty bag. No interrogation. We just refund you.</p>"
          }
        },
