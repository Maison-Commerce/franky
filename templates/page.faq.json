          "type": "faq_item",
          "settings": {
            "question": "What if I want to return an unopened bottle?",
            "answer": "<p>Unopened bags get full refunds within 90 days. Just email us. We'll send you a prepaid return label. You ship it back. We refund you when we receive it. Easy.</p>"
          }
        },
        "faq_item_diKU3d": {
          "type": "faq_item",
          "settings": {
            "question": "How do I get a refund?",
            "answer": "<p>Email <a href=\"mailto:hello@drinkarose.com\">hello@drinkarose.com</a> with your order number and why you want a refund. We process it within 1-2 business days. Money hits your account in 5-7 business days depending on your bank.</p>"
          }
        },
        "faq_item_UmKzHG": {
          "type": "faq_item",
          "settings": {
            "question": "Do you really honor the guarantee?",
            "answer": "<p>Yes. We've refunded hundreds of people. We don't fight you. We don't ask invasive questions. You say it didn't work, we refund you. Our refund rate is under 3% because the product works. But when someone asks, we honor it.</p>"
          }
