        "faq_item_kf7WKc": {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Orders are processed within 1 business day (Monday–Saturday). Once shipped, delivery takes 2–4 business days. Orders placed before 12:00 PM ET are processed the same day. All orders ship from our warehouse in Georgia, USA via USPS and partner delivery services.</p>"
          }
        },
        "faq_item_HYDRRx": {
          "type": "faq_item",
          "settings": {
            "question": "Is shipping free?",
            "answer": "<p>We offer free shipping on all orders over $50 within the United States. For orders below $50, a flat shipping fee of $4.99 applies.</p>"
          }
        },
        "faq_item_THwrEV": {
          "type": "faq_item",
          "settings": {
