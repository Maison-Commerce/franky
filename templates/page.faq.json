        "faq_item_cNfniY": {
          "type": "faq_item",
          "settings": {
            "question": "How does Subscribe & Save work?",
            "answer": "<p>Subscribe & Save delivers your Franky supply automatically at a discounted price so you never run out.</p>"
          }
        },
        "faq_item_GmW3HE": {
          "type": "faq_item",
          "settings": {
            "question": "Can I pause or cancel my subscription?",
            "answer": "<p>Yes. You can pause, skip, or cancel your subscription anytime through your account.</p>"
          }
        },
        "faq_item_gPpmLB": {
          "type": "faq_item",
          "settings": {
            "question": "Can I change my delivery schedule?",
            "answer": "<p>Absolutely. You can adjust delivery frequency or shipping dates whenever you need.</p>"
          }
        },
        "faq_item_wzh4rx": {
          "type": "faq_item",
          "settings": {
            "question": "How do I get a refund?",
            "answer": "<p> If there’s an issue with your order, our support team can assist with refunds according to our return policy.</p>"
          }
        },
        "faq_item_4xFyDq": {
          "type": "faq_item",
          "settings": {
            "question": "Are there bulk discounts?",
            "answer": "<p>Yes. Multi-bottle bundles and subscriptions typically offer the best savings.</p>"
          }
        }
