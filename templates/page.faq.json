    "faq_accordion_rPDPxR": {
      "type": "faq-accordion",
      "blocks": {
        "faq_item_dnzpxY": {
          "type": "faq_item",
          "settings": {
            "question": "How do I prepare Franky Protein Iced Coffee?",
            "answer": "<p>It's quick and easy — no coffee machine needed. Add 8oz of cold water or your favorite milk — almond milk or oat milk work great — into a glass, mix in one scoop of Franky Protein Iced Coffee, then shake or stir well. Add ice and enjoy. For the best taste, we recommend serving it over a full glass of ice. Feel free to customize with your favorite creamer or toppings. Want a stronger flavor or more protein? Just add a second scoop.</p>"
          }
        },
        "faq_item_VJTJcf": {
          "type": "faq_item",
          "settings": {
            "question": "Do I need a coffee machine to make it?",
            "answer": "<p>Not at all. Franky Protein Iced Coffee dissolves instantly in cold water or milk — no brewing, no machine, no hassle.</p>"
          }
        },
        "faq_item_Mdk9Jm": {
          "type": "faq_item",
          "settings": {
            "question": "Is this safe for long-term use?",
            "answer": "<p>Anytime that works for you. Enjoy it as your morning coffee, a pre-workout boost, a post-workout recovery drink, or an afternoon pick-me-up. It fits seamlessly into any part of your day. For the best taste and experience, we recommend serving it over ice.</p>"
          }
        }
      },
