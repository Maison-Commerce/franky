  .frk-compare td:first-child, .frk-compare th:first-child { text-align: left; font-weight: 600; padding-left: 16px; }
  .frk-compare .frk-col { background: #e8f2fb; color: #0e2540; font-weight: 800; }
  .frk-compare .frk-col-head { background: #2c5d8c; color: #fff; font-size: 14px; }
