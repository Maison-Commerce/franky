<script>
(function () {
  var PRODUCT_URL = 'https://frankynu.com/products/franky-protein-coffee';

  // Forward UTMs/click IDs from current URL to product link
  function buildCtaUrl() {
    try {
      var current = new URL(window.location.href);
      var target = new URL(PRODUCT_URL);
      current.searchParams.forEach(function (value, key) {
        if (/^(utm_|gclid|fbclid|msclkid|ttclid|wbraid|gbraid|nb_|campaignid|adgroupid|adname|placement|device|network|keyword|medium)/i.test(key)) {
          target.searchParams.set(key, value);
        }
      });
      return target.toString();
    } catch (e) { return PRODUCT_URL; }
  }

  function wireCtas() {
    var url = buildCtaUrl();
    document.querySelectorAll('[data-franky-cta]').forEach(function (el) { el.setAttribute('href', url); });
  }

  // 3-day rolling countdown (per visitor, stored in localStorage)
  function startCountdown() {
    var t = document.getElementById('frkTimer');
    if (!t) return;
    var dEl = t.querySelector('[data-d]'), hEl = t.querySelector('[data-h]'),
        mEl = t.querySelector('[data-m]'), sEl = t.querySelector('[data-s]');
    var KEY = 'frk_lst_deadline';
    var deadline = parseInt(localStorage.getItem(KEY) || '0', 10);
    var now = Date.now();
    if (!deadline || deadline < now) {
      deadline = now + 3 * 24 * 60 * 60 * 1000;
      try { localStorage.setItem(KEY, String(deadline)); } catch (e) {}
    }
    function pad(n) { return (n < 10 ? '0' : '') + n; }
    function tick() {
      var diff = Math.max(0, deadline - Date.now());
      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);
      dEl.textContent = pad(d); hEl.textContent = pad(h);
      mEl.textContent = pad(m); sEl.textContent = pad(s);
    }
    tick(); setInterval(tick, 1000);
  }

  function wireSticky() {
    var bar = document.getElementById('frkSticky'); if (!bar) return;
    function onScroll() {
      if (window.scrollY > 700 && window.innerWidth <= 720) bar.classList.add('visible');
      else bar.classList.remove('visible');
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { wireCtas(); startCountdown(); wireSticky(); });
  } else { wireCtas(); startCountdown(); wireSticky(); }
})();
</script>
