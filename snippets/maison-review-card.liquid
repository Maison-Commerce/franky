                <defs>
                    <linearGradient id="half-star-card-{{ block.id }}-{{ i }}">
                    <stop offset="50%" stop-color="#F79009"/>
                    <stop offset="50%" stop-color="#E0E0E0"/>
                    </linearGradient>
                </defs>
