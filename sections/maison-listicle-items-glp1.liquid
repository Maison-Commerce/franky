{%- liquid
  assign s = section.settings
-%}

<section
  id="shopify-section-{{ section.id }}-items-glp1"
  class="mli2"
  style="--mli2-bg: {{ s.bg_color }}; --mli2-accent: {{ s.accent_color }}; --mli2-body: {{ s.body_color }}; --mli2-pill-bg: {{ s.pill_bg }}; --mli2-pill-border: {{ s.pill_border }}; --mli2-pill-text: {{ s.pill_text_color }}; --mli2-pill-accent: {{ s.pill_accent_color }};"
>
  <div class="mli2__container" id="list-items-7-list">
    {%- for block in section.blocks -%}
      {%- if block.type == 'item' -%}
        {%- liquid
          if block.settings.number_override != blank
            assign item_number = block.settings.number_override
          else
            assign item_number = forloop.index | prepend: '0' | slice: -2, 2
          endif
        -%}
        <article class="mli2__item" {{ block.shopify_attributes }}>
          <div class="mli2__content">
            <header class="mli2__heading">
              <span class="mli2__number">{{ item_number }}</span>
              {%- if block.settings.title != blank -%}
                <h3 class="mli2__title">{{ block.settings.title }}</h3>
              {%- endif -%}
            </header>

            {%- if block.settings.body != blank -%}
              <div class="mli2__body">{{ block.settings.body }}</div>
            {%- endif -%}

            {%- if block.settings.pill != blank -%}
              <div class="mli2__pill-wrap">
                <div class="mli2__pill">{{ block.settings.pill }}</div>
              </div>
            {%- endif -%}
          </div>

          <div class="mli2__media">
            <div class="mli2__image-wrap">
              {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                <video
                  class="mli2__image mli2__video"
                  autoplay
                  muted
                  loop
                  playsinline
                  preload="metadata"
                  {% if block.settings.image != blank %}poster="{{ block.settings.image | image_url: width: 1200 }}"{% endif %}
                >
                  {%- for source in block.settings.video.sources -%}
                    <source src="{{ source.url }}" type="{{ source.mime_type }}">
                  {%- endfor -%}
                </video>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'mli2__image', sizes: '(max-width: 768px) 100vw, 560px' }}
              {%- else -%}
                <div class="mli2__image mli2__image--placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .mli2 {
    background: var(--mli2-bg);
    width: 100%;
    padding: 48px 0;
    display: flex;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    color: #3B2B2F;
  }
  .mli2__container {
    width: 100%;
    max-width: 1040px;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .mli2__item {
    display: flex;
    align-items: center;
    gap: 48px;
    width: 100%;
  }

  .mli2__content {
    flex: 0 0 400px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    justify-content: center;
  }
  .mli2__heading {
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: var(--mli2-accent);
    width: 100%;
  }
  .mli2__number {
    font-size: 18px;
    font-weight: 600;
    line-height: 1.5;
    color: var(--mli2-accent);
  }
  .mli2__title {
    margin: 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 32px;
    font-weight: 700;
    line-height: 1.18;
    color: var(--mli2-accent);
    text-transform: capitalize;
  }
  .mli2__title > p {
    margin: 0;
    font: inherit;
    color: inherit;
  }
  .mli2__title > p + p {
    margin-top: 0.15em;
  }
  .mli2__title strong { font-weight: 700; }
  .mli2__title em { font-style: italic; }
  .mli2__body {
    font-size: 18px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--mli2-body);
  }
  .mli2__body > p {
    margin: 0 0 1em 0;
  }
  .mli2__body > p:last-child {
    margin-bottom: 0;
  }

  /* Pill badge */
  .mli2__pill-wrap {
    display: inline-flex;
  }
  .mli2__pill {
    display: inline-flex;
    align-items: center;
    background: var(--mli2-pill-bg);
    border: 1px solid var(--mli2-pill-border);
    border-radius: 999px;
    padding: 5px 17px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--mli2-pill-text);
  }
  .mli2__pill > p {
    margin: 0;
  }
  .mli2__pill strong {
    color: var(--mli2-pill-accent);
    font-weight: 700;
  }
  .mli2__pill em {
    color: var(--mli2-pill-accent);
    font-style: normal;
  }

  /* Media (image right on desktop) */
  .mli2__media {
    flex: 1 1 0;
    min-width: 0;
  }
  .mli2__image-wrap {
    position: relative;
    width: 100%;
    height: 480px;
    border-radius: 16px;
    overflow: hidden;
    isolation: isolate;
  }
  .mli2__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mli2__image--placeholder {
    background: #D9D9D9;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .mli2 {
      padding: 48px 20px;
    }
    .mli2__container {
      max-width: 100%;
      gap: 40px;
    }
    .mli2__item {
      flex-direction: column;
      align-items: stretch;
      gap: 20px;
    }
    .mli2__media {
      width: 100%;
      flex: none;
      order: 2;
    }
    .mli2__image-wrap {
      height: 272px;
    }
    /* Flatten .mli2__content so its children sit alongside .mli2__media
       under .mli2__item — heading on top, image, body, pill. */
    .mli2__content {
      display: contents;
    }
    .mli2__heading {
      order: 1;
      gap: 4px;
    }
    .mli2__number {
      font-size: 16px;
      font-weight: 700;
      line-height: 1.4;
    }
    .mli2__title {
      font-size: 24px;
      line-height: 1.4;
    }
    .mli2__body {
      order: 3;
      font-size: 16px;
    }
    .mli2__pill-wrap {
      order: 4;
    }
    .mli2__pill {
      font-size: 12px;
      padding: 5px 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Listicle Items (GLP-1)",
