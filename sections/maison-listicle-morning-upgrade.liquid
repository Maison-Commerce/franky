{%- liquid
  assign s = section.settings
  assign review_blocks = section.blocks | where: 'type', 'review'

  assign rating = s.rating | default: 4.8
  assign rating_floor = rating | floor
  assign rating_remainder = rating | minus: rating_floor
  assign full_stars = rating_floor
  assign has_half = false
  if rating_remainder >= 0.25 and rating_remainder < 0.75
    assign has_half = true
  endif
  if rating_remainder >= 0.75
    assign full_stars = rating_floor | plus: 1
  endif
-%}

{%- capture star_full -%}
