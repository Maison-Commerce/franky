            "rating": 5,
            "date_text": "Bought on 18 August 2025",
            "quote": "I finally have energy that lasts all day. No crashes, no cravings. This is the only morning routine I've ever stuck with.",
            "reviewer_name": "Sarah K.",
            "verified_label": "Verified Buyer"
          }
