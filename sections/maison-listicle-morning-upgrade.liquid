{%- liquid
  assign s = section.settings
  assign photo_blocks = section.blocks | where: 'type', 'photo_review'
  assign text_blocks = section.blocks | where: 'type', 'text_review'

  assign rating = s.rating | default: 4.8
  assign rating_floor = rating | floor
  assign rating_remainder = rating | minus: rating_floor
  assign full_stars = rating_floor
  assign has_half = false
  if rating_remainder >= 0.25 and rating_remainder < 0.75
    assign has_half = true
  endif
  if rating_remainder >= 0.75
    assign full_stars = rating_floor | plus: 1
  endif

  comment
    Pad each marquee row so that even a couple of blocks fill the viewport.
    Each row repeats its block set enough times to reach ~8 cards minimum,
    then the track itself duplicates the whole padded set twice for the
    seamless -50% scroll.
  endcomment
  assign min_cards_per_row = 8

  assign photo_repeat = 1
  if photo_blocks.size > 0
    assign photo_repeat = min_cards_per_row | divided_by: photo_blocks.size | plus: 1 | at_most: 12
  endif

  assign text_repeat = 1
  if text_blocks.size > 0
    assign text_repeat = min_cards_per_row | divided_by: text_blocks.size | plus: 1 | at_most: 12
  endif
-%}

