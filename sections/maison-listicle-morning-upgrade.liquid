<section
  id="shopify-section-{{ section.id }}-morning-upgrade"
  class="mlmu"
  style="--mlmu-bg: {{ s.bg_color }}; --mlmu-text: {{ s.text_color }}; --mlmu-muted: {{ s.muted_color }}; --mlmu-card-bg: {{ s.card_bg }}; --mlmu-card-border: {{ s.card_border }}; --mlmu-author-bg: {{ s.author_pill_bg }}; --mlmu-verified: {{ s.verified_color }};"
  x-data="{
    videoOpen: false,
    activeSources: [],
    openVideo(sources) {
      this.activeSources = Array.isArray(sources) ? sources : [];
      this.videoOpen = true;
      document.documentElement.classList.add('mlmu-modal-open');
      this.$nextTick(() => {
        var vid = this.$refs.modalVid;
        if (!vid) return;
        while (vid.firstChild) vid.removeChild(vid.firstChild);
        this.activeSources.forEach(function (src) {
          var node = document.createElement('source');
          node.src = src.url;
          if (src.type) node.type = src.type;
          vid.appendChild(node);
        });
        vid.load();
        var p = vid.play();
        if (p && typeof p.catch === 'function') p.catch(function () {});
      });
    },
    closeVideo() {
      var vid = this.$refs.modalVid;
      if (vid) {
        try { vid.pause(); } catch (_) {}
        while (vid.firstChild) vid.removeChild(vid.firstChild);
        vid.removeAttribute('src');
        vid.load();
      }
      this.videoOpen = false;
      this.activeSources = [];
      document.documentElement.classList.remove('mlmu-modal-open');
    }
  }"
  @keydown.escape.window="if (videoOpen) closeVideo()"
>
  <div class="mlmu__container">
    <header class="mlmu__head">
      {%- if s.rating_label != blank -%}
        <div class="mlmu__rating">
          <span class="mlmu__stars" aria-hidden="true">
            {%- for i in (1..full_stars) -%}{{ star_full }}{%- endfor -%}
            {%- if has_half -%}{{ star_half }}{%- endif -%}
          </span>
          <span class="mlmu__rating-text">{{ s.rating_label }}</span>
        </div>
      {%- endif -%}

      {%- if s.title != blank -%}
        <h2 class="mlmu__title">{{ s.title }}</h2>
      {%- endif -%}

      {%- if s.subtitle != blank -%}
        <p class="mlmu__subtitle">{{ s.subtitle }}</p>
      {%- endif -%}
    </header>

    {%- comment -%} ===== ROW 1 — PHOTO CARDS ===== {%- endcomment -%}
    {%- if photo_blocks.size > 0 -%}
      {%- capture photo_card_set -%}
        {%- for i in (1..photo_repeat) -%}
          {%- for block in photo_blocks -%}
            <article class="mlmu__photo-card" {{ block.shopify_attributes }}>
              {%- if block.settings.video != blank -%}
                {%- comment -%}
                  Shopify-hosted video: poster + play button that opens the
                  section-level modal. Sources are embedded as an HTML-escaped
                  JSON string on a data attribute, then parsed on click — that
                  avoids the double-quote-inside-double-quote attribute trap.
                  Poster resolution order: client-set image > Shopify's
                  auto-generated video.preview_image > beige placeholder.
                {%- endcomment -%}
                {%- capture video_sources_json -%}[{%- for source in block.settings.video.sources -%}{"url":{{ source.url | json }},"type":{{ source.mime_type | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]{%- endcapture -%}
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mlmu__photo-img', alt: 'Video review' }}
                {%- elsif block.settings.video.preview_image != blank -%}
                  {{ block.settings.video.preview_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mlmu__photo-img', alt: 'Video review' }}
                {%- else -%}
                  <div class="mlmu__photo-img mlmu__photo-img--placeholder" aria-hidden="true"></div>
                {%- endif -%}
                <button
                  type="button"
                  class="mlmu__play mlmu__play--button"
                  data-mlmu-sources="{{ video_sources_json | escape }}"
                  @click="openVideo(JSON.parse($event.currentTarget.dataset.mlmuSources || '[]'))"
                  aria-label="Play video review"
                >{{ play_icon }}</button>
              {%- elsif block.settings.video_url != blank -%}
                {%- comment -%} External video link: poster image + play button overlay (new tab) {%- endcomment -%}
                <a class="mlmu__video-link" href="{{ block.settings.video_url }}" target="_blank" rel="noopener" aria-label="Play video review">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mlmu__photo-img', alt: 'Video review' }}
                  {%- else -%}
                    <div class="mlmu__photo-img mlmu__photo-img--placeholder" aria-hidden="true"></div>
                  {%- endif -%}
                  <span class="mlmu__play" aria-hidden="true">{{ play_icon }}</span>
                </a>
              {%- elsif block.settings.image != blank -%}
                {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'mlmu__photo-img', alt: 'Customer review' }}
              {%- else -%}
                <div class="mlmu__photo-img mlmu__photo-img--placeholder" aria-hidden="true"></div>
              {%- endif -%}
            </article>
          {%- endfor -%}
        {%- endfor -%}
      {%- endcapture -%}
      <div class="mlmu__viewport">
        <div class="mlmu__track" style="--mlmu-slide-duration: {{ s.photo_duration_seconds | default: 60 }}s;">
          {{ photo_card_set }}
          {{ photo_card_set }}
        </div>
      </div>
    {%- endif -%}

    {%- comment -%} ===== ROW 2 + 3 — TEXT-ONLY CARDS (both scroll left, bottom uses reversed order) ===== {%- endcomment -%}
    {%- if text_blocks.size > 0 -%}
      {%- assign text_blocks_reversed = text_blocks | reverse -%}

      {%- capture text_card_set -%}
        {%- for i in (1..text_repeat) -%}
          {%- for block in text_blocks -%}
            {%- assign r = block.settings.rating | default: 5 -%}
            <article class="mlmu__text-card" {{ block.shopify_attributes }}>
              <div class="mlmu__card-stars" aria-label="{{ r }} out of 5 stars">
                {%- for i in (1..r) -%}{{ star_full }}{%- endfor -%}
              </div>
              {%- if block.settings.date_text != blank -%}
                <div class="mlmu__card-date">{{ block.settings.date_text }}</div>
              {%- endif -%}
              {%- if block.settings.quote != blank -%}
                <p class="mlmu__card-quote">{{ block.settings.quote }}</p>
              {%- endif -%}
              <div class="mlmu__card-author">
                <span class="mlmu__card-name">{{ block.settings.reviewer_name }}</span>
                {%- if block.settings.verified_label != blank -%}
                  <span class="mlmu__card-dot" aria-hidden="true"></span>
                  <span class="mlmu__card-verified">
                    {{ check_badge }}
                    <span>{{ block.settings.verified_label }}</span>
                  </span>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        {%- endfor -%}
      {%- endcapture -%}

      {%- capture text_card_set_reversed -%}
        {%- for i in (1..text_repeat) -%}
          {%- for block in text_blocks_reversed -%}
            {%- assign r = block.settings.rating | default: 5 -%}
            <article class="mlmu__text-card" {{ block.shopify_attributes }}>
              <div class="mlmu__card-stars" aria-label="{{ r }} out of 5 stars">
                {%- for i in (1..r) -%}{{ star_full }}{%- endfor -%}
              </div>
              {%- if block.settings.date_text != blank -%}
                <div class="mlmu__card-date">{{ block.settings.date_text }}</div>
              {%- endif -%}
              {%- if block.settings.quote != blank -%}
                <p class="mlmu__card-quote">{{ block.settings.quote }}</p>
              {%- endif -%}
              <div class="mlmu__card-author">
                <span class="mlmu__card-name">{{ block.settings.reviewer_name }}</span>
                {%- if block.settings.verified_label != blank -%}
                  <span class="mlmu__card-dot" aria-hidden="true"></span>
                  <span class="mlmu__card-verified">
                    {{ check_badge }}
                    <span>{{ block.settings.verified_label }}</span>
                  </span>
                {%- endif -%}
              </div>
            </article>
          {%- endfor -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div class="mlmu__viewport">
        <div class="mlmu__track" style="--mlmu-slide-duration: {{ s.text_top_duration_seconds | default: 70 }}s;">
          {{ text_card_set }}
          {{ text_card_set }}
        </div>
      </div>
      <div class="mlmu__viewport">
        <div class="mlmu__track" style="--mlmu-slide-duration: {{ s.text_bottom_duration_seconds | default: 80 }}s;">
          {{ text_card_set_reversed }}
          {{ text_card_set_reversed }}
        </div>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} ===== VIDEO MODAL ===== {%- endcomment -%}
  <div
    class="mlmu__modal"
    x-show="videoOpen"
    x-cloak
    role="dialog"
    aria-modal="true"
    aria-label="Video review"
    @click.self="closeVideo()"
    x-transition.opacity
  >
    <div class="mlmu__modal-inner" @click.stop>
      <button
        type="button"
        class="mlmu__modal-close"
        @click="closeVideo()"
        aria-label="Close video"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
      <video
        x-ref="modalVid"
        class="mlmu__modal-video"
        controls
        playsinline
        preload="metadata"
      ></video>
    </div>
  </div>
</section>

<style>
  .mlmu {
    background: var(--mlmu-bg);
    width: 100%;
    padding: 56px 0 64px;
    display: flex;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    color: var(--mlmu-text);
    box-sizing: border-box;
  }
  .mlmu__container {
    width: 100%;
    max-width: 1440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
    box-sizing: border-box;
  }

  /* ===== Heading ===== */
  .mlmu__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    max-width: 600px;
    padding: 0 20px;
    text-align: center;
  }
  .mlmu__rating {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--mlmu-text);
  }
  .mlmu__stars {
    display: inline-flex;
    gap: 1px;
  }
  .mlmu__rating-text p {
    margin: 0;
    display: inline;
  }
  .mlmu__rating-text strong { font-weight: 700; }

  .mlmu__title {
    margin: 0;
    font-family: 'Lust Text', serif;
    font-size: 40px;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--mlmu-text);
  }
  .mlmu__title p { margin: 0; }
  .mlmu__subtitle {
    margin: 0;
    font-size: 18px;
    line-height: 1.5;
    color: var(--mlmu-muted);
  }

  /* ===== Marquee viewport (shared) ===== */
  .mlmu__viewport {
    width: 100%;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(to right, transparent, #000 48px, #000 calc(100% - 48px), transparent);
            mask-image: linear-gradient(to right, transparent, #000 48px, #000 calc(100% - 48px), transparent);
  }
  .mlmu__track {
    --mlmu-slide-gap: 18px;
    --mlmu-slide-duration: 60s;
    display: flex;
    gap: var(--mlmu-slide-gap);
    align-items: stretch;
    width: max-content;
    will-change: transform;
    animation: mlmu-marquee var(--mlmu-slide-duration) linear infinite;
  }
  .mlmu__track:hover,
  .mlmu__track:focus-within {
    animation-play-state: paused;
  }
  @keyframes mlmu-marquee {
    from { transform: translate3d(0, 0, 0); }
    to   { transform: translate3d(calc(-50% - var(--mlmu-slide-gap) / 2), 0, 0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mlmu__track { animation: none; transform: none; }
  }
  /* ===== Photo card (top row) ===== */
  .mlmu__photo-card {
    flex: 0 0 241px;
    width: 241px;
    height: 379px;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #E5E0D5;
    box-sizing: border-box;
  }
  .mlmu__play--button {
    appearance: none;
    border: none;
    cursor: pointer;
  }
  .mlmu__photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mlmu__photo-img--placeholder {
    background: linear-gradient(135deg, #E5E0D5 0%, #D5CFC0 100%);
  }
  .mlmu__video-link {
    position: absolute;
    inset: 0;
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .mlmu__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(59, 43, 47, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: transform 0.15s ease, background 0.15s ease;
    z-index: 2;
    pointer-events: none;
  }
  .mlmu__play svg { display: block; }
  .mlmu__video-link:hover .mlmu__play,
  .mlmu__video-link:focus-visible .mlmu__play {
    background: rgba(59, 43, 47, 0.75);
    transform: translate(-50%, -50%) scale(1.08);
  }
  .mlmu__video-link:focus-visible { outline: none; }
  /* The interactive play button override pointer-events:none so clicks register */
  .mlmu__play--button { pointer-events: auto; }
  .mlmu__play--button:hover,
  .mlmu__play--button:focus-visible {
    background: rgba(59, 43, 47, 0.75);
    transform: translate(-50%, -50%) scale(1.08);
    outline: none;
  }

  /* ===== Text card (bottom rows) ===== */
  .mlmu__text-card {
    flex: 0 0 340px;
    width: 340px;
    min-height: 175px;
    background: var(--mlmu-card-bg);
    border: 1px solid var(--mlmu-card-border);
    border-radius: 16px;
    padding: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    box-sizing: border-box;
  }

  /* ===== Shared card pieces ===== */
  .mlmu__card-stars {
    display: inline-flex;
    gap: 1px;
    justify-content: center;
  }
  .mlmu__card-date {
    font-size: 12px;
    color: var(--mlmu-muted);
    text-align: center;
    font-weight: 400;
  }
  .mlmu__card-quote {
    margin: 0;
    font-size: 16px;
    line-height: 1.5;
    color: var(--mlmu-muted);
    font-weight: 400;
    text-align: center;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .mlmu__card-author {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 12px;
    color: var(--mlmu-text);
    flex-wrap: wrap;
    padding: 4px 12px;
    border-radius: 999px;
    background: var(--mlmu-author-bg);
    width: fit-content;
    margin: 0 auto;
  }
  .mlmu__card-name {
    color: var(--mlmu-text);
    font-weight: 600;
  }
  .mlmu__card-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--mlmu-muted);
    display: inline-block;
  }
  .mlmu__card-verified {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-weight: 400;
  }
  .mlmu__check { flex-shrink: 0; }

  /* Mobile */
  @media (max-width: 1024px) {
    .mlmu { padding: 40px 0 48px; }
    .mlmu__container { gap: 20px; }
    .mlmu__title { font-size: 30px; }
    .mlmu__subtitle { font-size: 15px; }

    .mlmu__photo-card {
      flex: 0 0 200px;
      width: 200px;
      height: 314px;
    }
    .mlmu__text-card {
      flex: 0 0 280px;
      width: 280px;
      min-height: 160px;
      padding: 14px;
    }
    .mlmu__card-quote { font-size: 13px; }
    .mlmu__viewport {
      -webkit-mask-image: linear-gradient(to right, transparent, #000 16px, #000 calc(100% - 16px), transparent);
              mask-image: linear-gradient(to right, transparent, #000 16px, #000 calc(100% - 16px), transparent);
    }
  }

  /* ===== Video modal ===== */
  .mlmu__modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(15, 10, 12, 0.78);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    box-sizing: border-box;
  }
  .mlmu__modal-inner {
    position: relative;
    /* Reviews are filmed vertically (9:16). Drive the panel from height so
       the player stays as a portrait phone-sized rectangle on every screen. */
    height: min(90vh, 780px);
    aspect-ratio: 9 / 16;
    max-width: calc(100vw - 48px);
    background: #000;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }
  .mlmu__modal-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    background: #000;
  }
  .mlmu__modal-close {
    position: absolute;
    top: 8px;
    right: 8px;
    z-index: 2;
    appearance: none;
    border: none;
    background: rgba(15, 10, 12, 0.6);
    color: #FFFFFF;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .mlmu__modal-close:hover,
  .mlmu__modal-close:focus-visible {
    background: rgba(15, 10, 12, 0.85);
    outline: none;
  }
  /* Lock background scroll while the modal is open */
  html.mlmu-modal-open,
  html.mlmu-modal-open body {
    overflow: hidden;
  }

  @media (max-width: 640px) {
    .mlmu__modal { padding: 12px; }
    .mlmu__modal-close { width: 32px; height: 32px; top: 6px; right: 6px; }
  }
</style>

