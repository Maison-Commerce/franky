<section
  id="shopify-section-{{ section.id }}-built-for-morning"
  class="mlbm"
  style="--mlbm-bg: {{ s.bg_color }}; --mlbm-text: {{ s.text_color }}; --mlbm-muted: {{ s.muted_color }}; --mlbm-icon-bg: {{ s.icon_bg }}; --mlbm-icon-color: {{ s.icon_color }}; --mlbm-cta-bg: {{ s.cta_bg }}; --mlbm-cta-text: {{ s.cta_text_color }}; --mlbm-image-radius: {{ s.image_radius }}px;"
>
  <div class="mlbm__container">
    <div class="mlbm__content">
      <div class="mlbm__head">
        {%- if s.title != blank -%}
          <h2 class="mlbm__title mlbm__title--desktop">{{ s.title }}</h2>
        {%- endif -%}
        {%- if s.title_mobile != blank -%}
          <h2 class="mlbm__title mlbm__title--mobile">{{ s.title_mobile }}</h2>
        {%- endif -%}

        {%- if s.subtitle != blank -%}
          <p class="mlbm__subtitle mlbm__subtitle--desktop">{{ s.subtitle }}</p>
        {%- endif -%}
        {%- if s.subtitle_mobile != blank -%}
          <p class="mlbm__subtitle mlbm__subtitle--mobile">{{ s.subtitle_mobile }}</p>
        {%- endif -%}
      </div>

      {%- if feature_blocks.size > 0 -%}
        <ul class="mlbm__features">
          {%- for block in feature_blocks -%}
            {%- assign chosen_icon = block.settings.icon -%}
            <li class="mlbm__feature" {{ block.shopify_attributes }}>
              <div class="mlbm__feature-icon">
                {%- case chosen_icon -%}
                  {%- when 'stomach' -%}{{ icon_stomach }}
                  {%- when 'person' -%}{{ icon_person }}
                  {%- when 'cup' -%}{{ icon_cup }}
                  {%- else -%}{{ icon_stomach }}
                {%- endcase -%}
              </div>
              <div class="mlbm__feature-body">
                {%- if block.settings.title != blank -%}
                  <h3 class="mlbm__feature-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="mlbm__feature-text">{{ block.settings.body }}</div>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if s.cta_text != blank -%}
        <a class="mlbm__cta" href="{{ s.cta_url | default: '#' }}">
          <span>{{ s.cta_text }}</span>
        </a>
      {%- endif -%}
    </div>

    <div class="mlbm__media">
      <div class="mlbm__image-wrap">
        {%- if s.image != blank -%}
          {{ s.image | image_url: width: 1200 | image_tag:
            loading: 'lazy',
            class: 'mlbm__image',
            sizes: '(max-width: 1024px) 100vw, 600px',
            widths: '400, 600, 800, 1200'
          }}
        {%- else -%}
          <div class="mlbm__image mlbm__image--placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .mlbm {
    background: var(--mlbm-bg);
    width: 100%;
    padding: 64px 0;
    display: flex;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    color: var(--mlbm-text);
    box-sizing: border-box;
  }
  .mlbm__container {
    width: 100%;
    max-width: 1440px;
    padding: 0 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    box-sizing: border-box;
  }

  .mlbm__content {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .mlbm__head {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .mlbm__title {
    margin: 0;
    font-family: 'Lust Text', serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--mlbm-text);
    letter-spacing: -0.01em;
  }
  .mlbm__title p {
    margin: 0;
  }
  .mlbm__subtitle {
    margin: 0;
    font-size: 18px;
    line-height: 1.5;
    color: var(--mlbm-muted);
  }
  /* Hide mobile variants by default; toggle at breakpoint */
  .mlbm__title--mobile,
  .mlbm__subtitle--mobile {
    display: none;
  }

  .mlbm__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .mlbm__feature {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 24px;
    align-items: start;
  }
  .mlbm__feature-icon {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--mlbm-icon-bg);
    color: var(--mlbm-icon-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .mlbm__feature-icon svg {
    width: 28px;
    height: 28px;
    display: block;
  }
  .mlbm__feature-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mlbm__feature-title {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--mlbm-text);
  }
  .mlbm__feature-text {
    font-size: 16px;
    line-height: 1.5;
    color: var(--mlbm-muted);
  }
  .mlbm__feature-text p {
    margin: 0 0 0.5em 0;
  }
  .mlbm__feature-text p:last-child {
    margin-bottom: 0;
  }

  /* CTA */
  .mlbm__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    max-width: 600px;
    min-height: 56px;
    padding: 16px 32px;
    background: var(--mlbm-cta-bg);
    color: var(--mlbm-cta-text);
    border-radius: 16px;
    text-decoration: none;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1.2;
    box-sizing: border-box;
    transition: opacity 0.2s ease;
  }
  .mlbm__cta:hover,
  .mlbm__cta:focus-visible {
    opacity: 0.92;
    outline: none;
  }

  /* Media (right column) */
  .mlbm__media {
    width: 100%;
  }
  .mlbm__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--mlbm-image-radius);
    overflow: hidden;
  }
  .mlbm__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mlbm__image--placeholder {
    background: #D9D9D9;
  }

  /* Mobile / cramped desktop */
  @media (max-width: 1024px) {
    .mlbm {
      padding: 40px 0;
    }
    .mlbm__container {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 28px;
    }
    .mlbm__media {
      order: 1;
    }
    .mlbm__content {
      order: 2;
      gap: 28px;
      text-align: center;
      align-items: center;
    }
    .mlbm__head {
      text-align: center;
    }
    .mlbm__title {
      font-size: 32px;
    }
    .mlbm__subtitle {
      font-size: 16px;
    }
    /* Swap desktop/mobile copy on smaller screens */
    .mlbm__title--desktop,
    .mlbm__subtitle--desktop {
      display: none;
    }
    .mlbm__title--mobile,
    .mlbm__subtitle--mobile {
      display: block;
    }
    /* If no mobile copy provided, fall back to desktop on mobile */
    .mlbm__title--desktop:only-of-type,
    .mlbm__subtitle--desktop:only-of-type {
      display: block;
    }

    .mlbm__features {
      gap: 20px;
      width: 100%;
    }
    .mlbm__feature {
      grid-template-columns: 52px 1fr;
      gap: 16px;
      text-align: left;
    }
    .mlbm__feature-icon {
      width: 52px;
      height: 52px;
    }
    .mlbm__feature-icon svg {
      width: 20px;
      height: 20px;
    }
    .mlbm__feature-title {
      font-size: 18px;
    }
    .mlbm__feature-text {
      font-size: 15px;
    }
    .mlbm__cta {
      font-size: 14px;
      padding: 16px 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Listicle Built For",
  "tag": "section",
  "class": "section-maison-listicle-built-for-morning",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Background" },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#3B2B2F" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#3B2B2FBF" },

    { "type": "header", "content": "Heading (desktop)" },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Built For The Morning You Actually Have</p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Not the one where you have 15 minutes and a blender. The one where you have 60 seconds and need to work."
    },

    { "type": "header", "content": "Heading (mobile override)" },
    {
      "type": "richtext",
      "id": "title_mobile",
      "label": "Title (mobile)",
      "info": "Shown only on screens ≤1024px. Leave empty to use the desktop title.",
      "default": "<p>What's Inside Matters</p>"
    },
    {
      "type": "textarea",
      "id": "subtitle_mobile",
      "label": "Subtitle (mobile)",
      "info": "Shown only on screens ≤1024px. Leave empty to use the desktop subtitle.",
      "default": "Each ingredient is chosen for a reason — to energize, nourish, and support your body without unnecessary fillers."
    },

    { "type": "header", "content": "Image" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 16
    },

    { "type": "header", "content": "Feature icons" },
    { "type": "color", "id": "icon_bg", "label": "Icon background", "default": "#D8E4EE" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#3B2B2F" },

    { "type": "header", "content": "CTA" },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA text",
      "default": "SUBSCRIBE & SAVE 20% + FREE SHIPPING →"
    },
    { "type": "url", "id": "cta_url", "label": "CTA link" },
    { "type": "color", "id": "cta_bg", "label": "CTA background", "default": "#3B2B2F" },
    { "type": "color", "id": "cta_text_color", "label": "CTA text", "default": "#F7F3E6" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "stomach", "label": "Stomach / gut" },
            { "value": "person", "label": "Person" },
            { "value": "cup", "label": "Cup" }
          ],
          "default": "stomach"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Feature description.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Listicle Built For",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "stomach",
            "title": "Gut-Friendly Formula",
            "body": "<p>Added prebiotics and fiber support digestion and keep things moving — morning after morning.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "person",
            "title": "No Jitters, No Anxiety",
            "body": "<p>The L-theanine and caffeine ratio is dialed in specifically to energize without the edge. Smooth from the first sip.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "cup",
            "title": "Breakfast in One Cup",
            "body": "<p>Replaces your coffee and your protein shake in under 60 seconds. Two scoops into cold water or milk, thirty seconds to stir — one cup that handles your entire morning.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
