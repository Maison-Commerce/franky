            </a>
          {% endif %}
          {% if section.settings.social_facebook_url != blank %}
            <a href="{{ section.settings.social_facebook_url }}" class="maison_commerce_footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
