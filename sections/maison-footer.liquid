              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_tiktok_url != blank %}
            <a href="{{ section.settings.social_tiktok_url }}" class="maison_commerce_footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M16 7.71803V14.9727C16 18.5626 13.0899 21.4727 9.5 21.4727C5.91015 21.4727 3 18.5626 3 14.9727C3 11.3828 5.91015 8.47266 9.5 8.47266C10.0163 8.47266 10.5185 8.53285 11 8.64659V11.8095C10.5454 11.5935 10.0368 11.4727 9.5 11.4727C7.567 11.4727 6 13.0397 6 14.9727C6 16.9057 7.567 18.4727 9.5 18.4727C11.433 18.4727 13 16.9057 13 14.9727V1.47266H16C16 4.23408 18.2386 6.47266 21 6.47266V9.47266C19.1081 9.47266 17.3696 8.81594 16 7.71803Z" fill="#3B2B2F" fill-opacity="0.75"/>
