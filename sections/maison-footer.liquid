{% schema %}
{
  "name": "Maison Footer",
  "settings": [
    {
      "type": "header",
      "content": "Section Settings"
    },
    {
      "type": "color_background",
      "id": "footer_bg_color",
      "label": "Footer Background Color",
      "default": "#273928"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_left_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_right_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Right (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_left_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Left (Mobile)",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_right_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Padding Right (Mobile)",
      "default": 20
    },
    {
      "type": "header",
      "content": "Logo Settings"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo Image"
    },
    {
      "type": "image_picker",
      "id": "logo_image_bg",
      "label": "Logo Image Bottom"
    },
    {
      "type": "image_picker",
      "id": "logo_image_shape",
      "label": "Logo Image Bottom Shape"
    },
    {
      "type": "range",
      "id": "logo_width_desktop",
      "min": 100,
      "max": 200,
      "step": 1,
      "unit": "px",
      "label": "Logo Width (Desktop)",
      "default": 150
    },
    {
      "type": "range",
      "id": "logo_width_mobile",
      "min": 90,
      "max": 190,
      "step": 1,
      "unit": "px",
      "label": "Logo Width (Mobile)",
      "default": 120
    },
    {
      "type": "header",
      "content": "Newsletter Settings"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter Heading",
      "default": "Join And Get 10% Off"
    },
    {
      "type": "text",
      "id": "newsletter_subheading",
      "label": "Newsletter Subheading",
      "default": "Sign up for updates and exclusive offers!"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email Input Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "range",
      "id": "newsletter_heading_font_size_desktop",
      "min": 20,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Newsletter Heading Font Size (Desktop)",
      "default": 32
    },
    {
      "type": "range",
      "id": "newsletter_heading_font_size_mobile",
      "min": 18,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Newsletter Heading Font Size (Mobile)",
      "default": 24
    },
    {
      "type": "color",
      "id": "newsletter_text_color",
      "label": "Newsletter Text Color",
      "default": "#B9FCAB"
    },
    {
      "type": "color",
      "id": "newsletter_input_bg_color",
      "label": "Email Input Background Color",
      "default": "#2E432F"
    },
    {
      "type": "color",
      "id": "newsletter_input_text_color",
      "label": "Email Input Text Color",
      "default": "#B9FCAB"
    },
    {
      "type": "color",
      "id": "newsletter_button_bg_color",
      "label": "Submit Button Background Color",
      "default": "#B9FCAB"
    },
    {
      "type": "color",
      "id": "newsletter_button_icon_color",
      "label": "Submit Button Icon Color",
      "default": "#273928"
    },
    {
      "type": "header",
      "content": "Social Media Settings"
    },
    {
      "type": "url",
      "id": "social_youtube_url",
      "label": "YouTube URL"
    },
    {
      "type": "url",
      "id": "social_instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_pinterest_url",
      "label": "Pinterest URL"
    },
    {
      "type": "color",
      "id": "social_icon_color",
      "label": "Social Icon Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Background Logo"
    },
    {
      "type": "checkbox",
      "id": "show_background_logo",
      "label": "Show Background Logo",
      "default": true
    },
    {
      "type": "color",
      "id": "background_logo_color",
      "label": "Background Logo Color",
      "default": "#2E432F"
    },
    {
      "type": "range",
      "id": "background_logo_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Logo Opacity",
      "default": 10
    },
    {
      "type": "header",
      "content": "Typography Settings"
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 16,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Section Heading Font Size (Desktop)",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 16,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Section Heading Font Size (Mobile)",
      "default": 18
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Section Heading Color",
      "default": "#B9FCAB"
    },
    {
      "type": "range",
      "id": "link_font_size_desktop",
      "min": 12,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Link Font Size (Desktop)",
      "default": 14
    },
    {
      "type": "range",
      "id": "link_font_size_mobile",
      "min": 12,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "Link Font Size (Mobile)",
      "default": 14
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link Color",
      "default": "#E9EBE9"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link Hover Color",
      "default": "#B9FCAB"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Navigate"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Select a menu for this link list"
        }
      ]
    },
    {
      "type": "custom_link_list",
      "name": "Custom Link List",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Shipping & Returns"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Select a menu for this link list"
        }
      ]
    },
    {
      "type": "customer_support",
      "name": "Customer Support",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p><a href=\"mailto:support@drinkarose.com\">support@drinkarose.com</a></p><p><a href=\"#\">Live Chat</a></p><p><a href=\"tel:1-800-XXX-XXXX\">1-800-XXX-XXXX</a></p><p>Avg response: 2 hours</p>"
        },
        {
          "type": "checkbox",
          "id": "show_payment_methods",
          "label": "Show Payment Methods",
          "default": true
        }
      ]
    },
    {
      "type": "link",
      "name": "Link",
      "settings": [
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Privacy Policy"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "Maison Footer",
      "blocks": [
        {
          "type": "link_list",
          "settings": {
            "heading": "Navigate"
          }
        },
        {
          "type": "custom_link_list",
          "settings": {
            "heading": "Shipping & Returns"
          }
        },
        {
          "type": "customer_support",
          "settings": {
            "show_payment_methods": true
          }
        },
        {
          "type": "link",
          "settings": {
            "link_text": "Privacy Policy",
            "link_url": "/policies/privacy-policy"
          }
        },
        {
          "type": "link",
          "settings": {
            "link_text": "Terms of Service",
            "link_url": "/policies/terms-of-service"
          }
        },
        {
          "type": "link",
          "settings": {
            "link_text": "Refund Policy",
            "link_url": "/policies/refund-policy"
          }
        },
        {
          "type": "link",
          "settings": {
            "link_text": "Shipping & Returns",
            "link_url": "/policies/shipping-policy"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<footer class="maison_commerce_footer">
  <div class="maison_commerce_footer__container" style="padding-top: {{ section.settings.padding_top_desktop }}px; padding-bottom: {{ section.settings.padding_bottom_desktop }}px; padding-left: {{ section.settings.padding_left_desktop }}px; padding-right: {{ section.settings.padding_right_desktop }}px;">
    <div class="maison_commerce_footer__content">
      <div class="maison_commerce_footer__left">
        <div class="maison_commerce_footer__left-top-content">
            {% if section.settings.logo_image != blank %}
            <div class="maison_commerce_footer__logo">
                {{
                section.settings.logo_image
                | image_url: width: 300
                | image_tag: loading: 'lazy', alt: 'Logo', class: 'maison_commerce_footer__logo-img'
                }}
            </div>
            {% endif %}

            <div class="maison_commerce_footer__left-top-content-text">
                {% if section.settings.newsletter_heading != blank %}
                <h2 class="maison_commerce_footer__newsletter-heading">
                    {{ section.settings.newsletter_heading }}
                </h2>
                {% endif %}

                {% if section.settings.newsletter_subheading != blank %}
                <p class="maison_commerce_footer__newsletter-subheading">
                    {{ section.settings.newsletter_subheading }}
                </p>
                {% endif %}
            </div>
        </div>

        {% form 'customer', class: 'maison_commerce_footer__newsletter-form' %}
          <input 
            type="hidden" 
            name="contact[tags]" 
            value="newsletter"
          />
          <input 
            type="email" 
            name="contact[email]" 
            placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
            class="maison_commerce_footer__newsletter-input"
            required
            aria-label="Email address"
          />
          <button type="submit" class="maison_commerce_footer__newsletter-button" aria-label="Subscribe">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 12L10 8L6 4" stroke="#FFFDF5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {% endform %}
      </div>

      <div class="maison_commerce_footer__middle">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'link_list' %}
              {% if block.settings.heading != blank %}
                <div class="maison_commerce_footer__link-group" {{ block.shopify_attributes }}>
                  <h3 class="maison_commerce_footer__link-group-heading">
                    {{ block.settings.heading }}
                  </h3>
                  {% if block.settings.menu != blank %}
                    <ul class="maison_commerce_footer__link-list">
                      {% for link in linklists[block.settings.menu].links %}
                        <li>
                          <a href="{{ link.url }}" class="maison_commerce_footer__link">
                            {{ link.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
        <div class="maison_commerce_footer__right">
            {% for block in section.blocks %}
                {% case block.type %}
                    {% when 'custom_link_list' %}
                    {% if block.settings.heading != blank %}
                        <div class="maison_commerce_footer__link-group" {{ block.shopify_attributes }}>
                        <h3 class="maison_commerce_footer__link-group-heading">
                            {{ block.settings.heading }}
                        </h3>
                        {% if block.settings.menu != blank %}
                            <ul class="maison_commerce_footer__link-list">
                            {% for link in linklists[block.settings.menu].links %}
                                <li>
                                <a href="{{ link.url }}" class="maison_commerce_footer__link">
                                    {{ link.title }}
                                </a>
                                </li>
                            {% endfor %}
                            </ul>
                        {% endif %}
                        </div>
                    {% endif %}
                    {% when 'customer_support' %}
                    <div class="maison_commerce_footer__support" {{ block.shopify_attributes }}>
                        <h3 class="maison_commerce_footer__link-group-heading">
                        Customer Support
                        </h3>
                        <div class="maison_commerce_footer__social">
                          {% if section.settings.social_youtube_url != blank %}
                            <a href="{{ section.settings.social_youtube_url }}" class="maison_commerce_footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M12.2439 3.47266C12.778 3.4756 14.1143 3.48852 15.5341 3.54539L16.0375 3.56734C17.467 3.63502 18.8953 3.75064 19.6037 3.94816C20.5486 4.21361 21.2913 4.98816 21.5423 5.96998C21.942 7.52907 21.992 10.5721 21.9982 11.3085L21.9991 11.4611V11.4718C21.9991 11.4718 21.9991 11.4755 21.9991 11.4826L21.9982 11.6352C21.992 12.3716 21.942 15.4146 21.5423 16.9737C21.2878 17.9591 20.5451 18.7337 19.6037 18.9955C18.8953 19.193 17.467 19.3086 16.0375 19.3763L15.5341 19.3982C14.1143 19.4551 12.778 19.468 12.2439 19.471L12.0095 19.4718H11.9991C11.9991 19.4718 11.9956 19.4718 11.9887 19.4718L11.7545 19.471C10.6241 19.4648 5.89772 19.4137 4.39451 18.9955C3.4496 18.73 2.70692 17.9555 2.45587 16.9737C2.0562 15.4146 2.00624 12.3716 2 11.6352V11.3085C2.00624 10.5721 2.0562 7.52907 2.45587 5.96998C2.7104 4.98452 3.45308 4.20998 4.39451 3.94816C5.89772 3.52989 10.6241 3.47888 11.7545 3.47266H12.2439ZM9.99911 7.9718V14.9718L15.9991 11.4718L9.99911 7.9718Z" fill="#3B2B2F" fill-opacity="0.75"/>
                              </svg>
                            </a>
                          {% endif %}
                          {% if section.settings.social_instagram_url != blank %}
                            <a href="{{ section.settings.social_instagram_url }}" class="maison_commerce_footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
