              </svg>
            </a>
          {% endif %}
        </div>

        {% form 'customer', class: 'maison_commerce_footer__newsletter-form' %}
          <input 
            type="hidden" 
            name="contact[tags]" 
            value="newsletter"
          />
          <input 
            type="email" 
            name="contact[email]" 
            placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
            class="maison_commerce_footer__newsletter-input"
            required
            aria-label="Email address"
          />
          <button type="submit" class="maison_commerce_footer__newsletter-button" aria-label="Subscribe">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M6 12L10 8L6 4" stroke="#FFFDF5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        {% endform %}
      </div>

      <div class="maison_commerce_footer__middle">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'link_list' %}
              {% if block.settings.heading != blank %}
                <div class="maison_commerce_footer__link-group" {{ block.shopify_attributes }}>
                  <h3 class="maison_commerce_footer__link-group-heading">
                    {{ block.settings.heading }}
                  </h3>
                  {% if block.settings.menu != blank %}
                    <ul class="maison_commerce_footer__link-list">
                      {% for link in linklists[block.settings.menu].links %}
                        <li>
                          <a href="{{ link.url }}" class="maison_commerce_footer__link">
                            {{ link.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </div>
              {% endif %}
          {% endcase %}
        {% endfor %}
        <div class="maison_commerce_footer__right">
            {% for block in section.blocks %}
                {% case block.type %}
                    {% when 'custom_link_list' %}
                    {% if block.settings.heading != blank %}
                        <div class="maison_commerce_footer__link-group" {{ block.shopify_attributes }}>
                        <h3 class="maison_commerce_footer__link-group-heading">
                            {{ block.settings.heading }}
                        </h3>
                        {% if block.settings.menu != blank %}
                            <ul class="maison_commerce_footer__link-list">
                            {% for link in linklists[block.settings.menu].links %}
                                <li>
                                <a href="{{ link.url }}" class="maison_commerce_footer__link">
                                    {{ link.title }}
                                </a>
                                </li>
                            {% endfor %}
                            </ul>
                        {% endif %}
                        </div>
                    {% endif %}
                    {% when 'customer_support' %}
                    <div class="maison_commerce_footer__support" {{ block.shopify_attributes }}>
                        <h3 class="maison_commerce_footer__link-group-heading">
                        Customer Support
                        </h3>
                        {% if block.settings.content != blank %}
                        <div class="maison_commerce_footer__support-content">
                            {{ block.settings.content }}
                        </div>
                        {% endif %}
                        {% if block.settings.show_payment_methods %}
