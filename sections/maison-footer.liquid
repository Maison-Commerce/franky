    {% if section.settings.show_background_logo and section.settings.logo_image_bg != blank %}
      <div class="maison_commerce_footer__background-logo">
        {{
          section.settings.logo_image_bg
          | image_url: width: 1440
          | image_tag: loading: 'lazy', alt: 'Background Logo', class: 'maison_commerce_footer__background-logo-img'
        }}
      </div>
    {% endif %}
  </div>
  {% if section.settings.logo_image_shape != blank %}
    {{
        section.settings.logo_image_shape
        | image_url: width: 1440
        | image_tag: loading: 'lazy', alt: 'Background Logo', class: 'maison_commerce_footer__background-logo-img-shape'
    }}
  {% endif %}
</footer>

<style>
  .maison_commerce_footer-top-divider{
    display: flex!important;
    border-radius: 32px 32px 0 0;
    background: #2E432F;
    width: 100%;
    height: 80px;
    margin-top: -16px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer-top-divider{
        height: 20px;
        margin-top: -8px;
    }
  }

  .maison_commerce_footer {
    position: relative;
    width: 100%;
    background: {{ section.settings.footer_bg_color }};
    overflow: hidden;
  }

  .maison_commerce_footer__background-logo-img-shape{
    position: absolute;
    bottom: 0;
    width: 100%;
    left: 0;
    right: 0;
  }

  .maison_commerce_footer__container {
    max-width: 1440px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__background-logo-img-shape{
        max-height: 55vw;
    }

    .maison_commerce_footer__container {
      padding-top: {{ section.settings.padding_top_mobile }}px !important;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px !important;
      padding-left: {{ section.settings.padding_left_mobile }}px !important;
      padding-right: {{ section.settings.padding_right_mobile }}px !important;
    }
  }

  .maison_commerce_footer__content {
    display: flex;
    gap: 64px;
    align-items: flex-start;
    justify-content: space-between;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__content {
      flex-direction: column;
      gap: 18px;
    }
  }

  .maison_commerce_footer__left {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
    max-width: 365px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__left {
      gap: 18px;
      max-width: 100%;
    }
  }

  .maison_commerce_footer__left-top-content{
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__left-top-content{
        gap: 18px;
        align-items: center;
    }
  }

  .maison_commerce_footer__left-top-content-text{
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__left-top-content-text{
        align-items: center;
    }
  }

  .maison_commerce_footer__logo {
    margin: 0;
  }

  .maison_commerce_footer__logo-img {
    width: {{ section.settings.logo_width_desktop }}px;
    height: auto;
    display: block;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__logo-img {
      width: {{ section.settings.logo_width_mobile }}px;
    }
  }

  .maison_commerce_footer__newsletter-heading {
    font-family: 'Lust Text', serif;
    font-size: {{ section.settings.newsletter_heading_font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.2;
    color: {{ section.settings.newsletter_text_color }};
    margin: 0;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__newsletter-heading {
      font-size: {{ section.settings.newsletter_heading_font_size_mobile }}px;
    }
  }

  .maison_commerce_footer__newsletter-subheading {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.5;
    color: #3B2B2F;
    margin: 0;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__newsletter-subheading {
      font-size: 16px;
    }
  }

  .maison_commerce_footer__payments{
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .maison_commerce_footer__payments svg{
    width: 29px;
    height: 20px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__payments{
        gap: 8px;
    }

    .maison_commerce_footer__payments svg{
        width: 33.558px;
        height: 23.011px;
    }
  }

  .maison_commerce_footer__newsletter-form {
    display: flex;
    gap: 12px;
    align-items: center;
    width: 100%;
    padding: 12px 12px 12px 16px;
    border-radius: 8px;
    background: rgba(59, 43, 47, 0.05);
  }

  .maison_commerce_footer__newsletter-form .h-captcha{
    display: none;
  }

  .maison_commerce_footer__newsletter-input {
    flex: 1;
    background: transparent;
    color: {{ section.settings.newsletter_input_text_color }};
    border: none;
    border-radius: 0;
    padding: 0;
    font-family: 'Geist', sans-serif;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    min-width: 0;
    width: 100%;
  }

  .maison_commerce_footer__newsletter-input::placeholder {
    color: {{ section.settings.newsletter_input_text_color | color_modify: 'alpha', 0.6 }};
  }

  .maison_commerce_footer__newsletter-input:focus {
    outline: none;
  }

  .maison_commerce_footer__newsletter-button {
    width: 20px;
    height: 20px;
    padding: 2px;
    background-color: {{ section.settings.newsletter_button_bg_color }};
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    color: {{ section.settings.newsletter_button_icon_color }};
    transition: opacity 0.3s ease;
  }

  .maison_commerce_footer__newsletter-button:hover {
    opacity: 0.9;
  }

  .maison_commerce_footer__newsletter-button svg {
    width: 24px;
    height: 24px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__newsletter-form {
      gap: 8px;
    }

    .maison_commerce_footer__newsletter-input {
      font-size: 14px;
    }
  }

  .maison_commerce_footer__newsletter-input:focus-visible{
    outline: none;
    outline-offset: initial;
    box-shadow: none;
  }

  .maison_commerce_footer__social {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .maison_commerce_footer__social-link {
    color: {{ section.settings.social_icon_color }};
    transition: opacity 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .maison_commerce_footer__social-link:hover {
    opacity: 0.8;
  }

  .maison_commerce_footer__social-link svg {
    width: 24px;
    height: 24px;
  }

  .maison_commerce_footer__middle{
    display: flex;
    gap: 64px;
    width: 100%;
    flex-wrap: wrap;
  }

  .maison_commerce_footer__right {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
    max-width: 367px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__middle,
    .maison_commerce_footer__right {
      gap: 18px;
    }

    .maison_commerce_footer__right {
      max-width: 410px;
    }
  }

  .maison_commerce_footer__link-group {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 178px;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__link-group {
      gap: 8px;
      max-width: 158.5px;
    }
  }

  .maison_commerce_footer__link-group-heading {
    font-family: 'Lust Text', serif;
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.4;
    color: {{ section.settings.heading_color }};
    margin: 0;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__link-group-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
  }

  .maison_commerce_footer__link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    color: {{ section.settings.link_color | hex_to_rgba: 0.75 }};
    transition: all 0.3s ease;
    font-family: 'Geist', sans-serif;
    font-size: 14px;
    line-height: 1.5;
    font-weight: 400;
  }

  .maison_commerce_footer__link-list li{
    padding: 8px 0;
  }

  .maison_commerce_footer__link-list:hover{
    color: {{ section.settings.link_color_hover }};
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__link-list li{
      padding: 4px 0;
    }
  }

  .maison_commerce_footer__support{
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .maison_commerce_footer__support-content {
    font-family: 'Geist', sans-serif;
    font-size: {{ section.settings.link_font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.5;
    color: {{ section.settings.link_color | hex_to_rgba: 0.75 }};
  }

  .maison_commerce_footer__support-content p {
    margin: 0;
  }

  .maison_commerce_footer__support-content p:last-child {
    margin-bottom: 0;
  }

  .maison_commerce_footer__support-content a {
    color: {{ section.settings.link_color | hex_to_rgba: 0.75 }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .maison_commerce_footer__support-content a:hover {
    color: {{ section.settings.link_hover_color }};
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__support-content {
      font-size: {{ section.settings.link_font_size_mobile }}px;
    }
  }

  .maison_commerce_footer__link {
    font-family: "Avenir Next", sans-serif;
    font-size: {{ section.settings.link_font_size_desktop }}px;
    font-weight: 400;
    line-height: 1.5;
    color: {{ section.settings.link_color | hex_to_rgba: 0.75 }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .maison_commerce_footer__link:hover {
    color: {{ section.settings.link_hover_color }};
  }


  @media (max-width: 1050px) {
    .maison_commerce_footer__link {
      font-size: {{ section.settings.link_font_size_mobile }}px;
    }
  }

  .maison_commerce_footer__payment-icons {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
  }

  .maison_commerce_footer__payment-icon {
    background: {{ section.settings.footer_bg_color }};
    border: 1px solid {{ section.settings.link_color | color_modify: 'alpha', 0.2 }};
    border-radius: 6px;
    padding: 6px 12px;
    font-family: "Avenir Next", sans-serif;
    font-size: 11px;
    font-weight: 500;
    color: {{ section.settings.link_color }};
    white-space: nowrap;
  }

  .maison_commerce_footer__background-logo {
    position: relative;
    width: 100%;
    max-width: 1440px;
    margin: 80px auto 0;
    z-index: 1;
    display: flex;
  }

  .maison_commerce_footer__background-logo-img {
    width: 100%;
    height: auto;
  }

  @media (max-width: 1050px) {
    .maison_commerce_footer__background-logo {
      margin-top: 32px;
    }
  }
</style>

