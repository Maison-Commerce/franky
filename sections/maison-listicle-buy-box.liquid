{%- liquid
  assign s = section.settings
  assign p = s.product
  assign pack_blocks = section.blocks | where: 'type', 'pack_option'
  assign trust_blocks = section.blocks | where: 'type', 'trust_badge'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'
  assign taste_blocks = section.blocks | where: 'type', 'taste_tile'
-%}

{%- if p == blank -%}
  <section class="mlbb mlbb--empty" id="shopify-section-{{ section.id }}-buy-box">
    <div class="mlbb__container">
      <p class="mlbb__placeholder">Select a product in the section settings to display the buy box.</p>
    </div>
  </section>
{%- else -%}

<section
  id="shopify-section-{{ section.id }}-buy-box"
  class="mlbb"
  style="
    --mlbb-bg: {{ s.bg_color }};
    --mlbb-text: {{ s.text_color }};
    --mlbb-muted: {{ s.muted_color }};
    --mlbb-card-bg: {{ s.card_bg }};
    --mlbb-image-bg: {{ s.image_bg }};
    --mlbb-pill-bg: {{ s.pill_bg }};
    --mlbb-pill-text: {{ s.pill_text_color }};
    --mlbb-pack-bg: {{ s.pack_bg }};
    --mlbb-pack-border: {{ s.pack_border }};
    --mlbb-pack-active: {{ s.pack_active_border }};
    --mlbb-save-bg: {{ s.save_bg }};
    --mlbb-save-text: {{ s.save_text_color }};
    --mlbb-best-bg: {{ s.best_bg }};
    --mlbb-best-text: {{ s.best_text_color }};
    --mlbb-cta-bg: {{ s.cta_bg }};
    --mlbb-cta-text: {{ s.cta_text_color }};
    --mlbb-star: {{ s.star_color }};
    --mlbb-select-bg: {{ s.select_bg }};
    --mlbb-select-border: {{ s.select_border }};
    --mlbb-stock-highlight: {{ s.stock_highlight_color }};
    --mlbb-taste-bg: {{ s.taste_bg }};
    --mlbb-taste-text: {{ s.taste_text_color }};
  "
  x-data="maisonListicleBuyBox()"
  x-cloak
>
  <div class="mlbb__container" id="listicle-pr-main">
    <div class="mlbb__grid">
      {%- comment -%} ========= IMAGE COLUMN ========= {%- endcomment -%}
      <div class="mlbb__media">
        <div class="mlbb__gallery">
          <div class="mlbb__thumbs-wrap">
            <div class="mlbb__thumbs" role="tablist" aria-label="Product image thumbnails">
              {%- for image in p.images limit: 12 -%}
                <button
                  type="button"
                  class="mlbb__thumb"
                  :class="{ 'is-active': activeImageIndex === {{ forloop.index0 }} }"
                  @click="activeImageIndex = {{ forloop.index0 }}"
                  role="tab"
                  aria-label="Image {{ forloop.index }}"
                >
                  {{ image | image_url: width: 200 | image_tag: loading: 'lazy', class: 'mlbb__thumb-img', alt: image.alt | default: p.title }}
                </button>
              {%- endfor -%}
            </div>
          </div>

          <div class="mlbb__main-image">
            {%- for image in p.images limit: 6 -%}
              <div class="mlbb__slide" x-show="activeImageIndex === {{ forloop.index0 }}">
                {{ image | image_url: width: 1200 | image_tag: loading: 'eager', class: 'mlbb__main-img', alt: image.alt | default: p.title }}
              </div>
            {%- endfor -%}
          </div>
        </div>

        {%- if s.show_nutritional_button -%}
          <div class="mlbb__nutrition mlbb__nutrition--desktop">
            <button type="button" class="mlbb__nutrition-toggle" @click="nutritionOpen = !nutritionOpen" :aria-expanded="nutritionOpen">
              <svg class="mlbb__nutrition-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
              <span>{{ s.nutritional_button_text | default: 'Nutritional Information' }}</span>
            </button>
            <div class="mlbb__nutrition-body" x-show="nutritionOpen" x-collapse>
              {{ s.nutritional_content }}
            </div>
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} ========= CONTENT COLUMN ========= {%- endcomment -%}
      <div class="mlbb__content">
        {%- if s.pill_text != blank -%}
          <div class="mlbb__pill">
            {%- if s.pill_icon != blank -%}<span class="mlbb__pill-icon">{{ s.pill_icon }}</span>{%- endif -%}
            <span>{{ s.pill_text }}</span>
          </div>
        {%- endif -%}

        <h1 class="mlbb__title">{{ s.title_override | default: p.title }}</h1>

        {%- if s.rating > 0 -%}
          <div class="mlbb__rating">
            <span class="mlbb__stars" aria-hidden="true">
              {%- assign rating = s.rating -%}
              {%- assign full_stars = rating | floor -%}
              {%- assign rating_remainder = rating | minus: full_stars -%}
              {%- assign has_half = false -%}
              {%- if rating_remainder >= 0.25 and rating_remainder < 0.75 -%}{%- assign has_half = true -%}{%- endif -%}
              {%- if rating_remainder >= 0.75 -%}{%- assign full_stars = full_stars | plus: 1 -%}{%- endif -%}
              {%- for i in (1..full_stars) -%}
                <svg class="franky-rating-star mlbb__star" width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M13.94 5.04C13.81 4.69 13.47 4.45 13.09 4.45H9.43C9.31 4.45 9.19 4.37 9.15 4.25L7.84 0.56C7.7 0.22 7.37 0 7 0C6.62 0 6.28 0.24 6.15 0.59L4.84 4.26C4.79 4.38 4.68 4.46 4.56 4.46H0.9C0.52 4.46 0.18 4.7 0.05 5.05C-0.07 5.4 0.03 5.79 0.32 6.03L3.43 8.59C3.53 8.66 3.57 8.79 3.53 8.91L2.22 12.79C2.09 13.16 2.22 13.57 2.54 13.8C2.86 14.03 3.29 14.02 3.61 13.79L6.81 11.46C6.92 11.39 7.06 11.39 7.17 11.46L10.38 13.79C10.7 14.05 11.15 14.07 11.48 13.83C11.82 13.6 11.95 13.17 11.8 12.79L10.49 8.91C10.45 8.79 10.49 8.66 10.59 8.59L13.7 6.03C13.98 5.78 14.07 5.38 13.94 5.04Z" fill="var(--mlbb-star)"/>
                </svg>
              {%- endfor -%}
              {%- if has_half -%}
                <svg class="franky-rating-star mlbb__star" width="16" height="16" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <defs><clipPath id="mlbb-half-{{ section.id }}"><rect width="7" height="14"/></clipPath></defs>
                  <path d="M13.94 5.04C13.81 4.69 13.47 4.45 13.09 4.45H9.43C9.31 4.45 9.19 4.37 9.15 4.25L7.84 0.56C7.7 0.22 7.37 0 7 0C6.62 0 6.28 0.24 6.15 0.59L4.84 4.26C4.79 4.38 4.68 4.46 4.56 4.46H0.9C0.52 4.46 0.18 4.7 0.05 5.05C-0.07 5.4 0.03 5.79 0.32 6.03L3.43 8.59C3.53 8.66 3.57 8.79 3.53 8.91L2.22 12.79C2.09 13.16 2.22 13.57 2.54 13.8C2.86 14.03 3.29 14.02 3.61 13.79L6.81 11.46C6.92 11.39 7.06 11.39 7.17 11.46L10.38 13.79C10.7 14.05 11.15 14.07 11.48 13.83C11.82 13.6 11.95 13.17 11.8 12.79L10.49 8.91C10.45 8.79 10.49 8.66 10.59 8.59L13.7 6.03C13.98 5.78 14.07 5.38 13.94 5.04Z" fill="#D2D2D2"/>
                  <path d="M13.94 5.04C13.81 4.69 13.47 4.45 13.09 4.45H9.43C9.31 4.45 9.19 4.37 9.15 4.25L7.84 0.56C7.7 0.22 7.37 0 7 0C6.62 0 6.28 0.24 6.15 0.59L4.84 4.26C4.79 4.38 4.68 4.46 4.56 4.46H0.9C0.52 4.46 0.18 4.7 0.05 5.05C-0.07 5.4 0.03 5.79 0.32 6.03L3.43 8.59C3.53 8.66 3.57 8.79 3.53 8.91L2.22 12.79C2.09 13.16 2.22 13.57 2.54 13.8C2.86 14.03 3.29 14.02 3.61 13.79L6.81 11.46C6.92 11.39 7.06 11.39 7.17 11.46L10.38 13.79C10.7 14.05 11.15 14.07 11.48 13.83C11.82 13.6 11.95 13.17 11.8 12.79L10.49 8.91C10.45 8.79 10.49 8.66 10.59 8.59L13.7 6.03C13.98 5.78 14.07 5.38 13.94 5.04Z" fill="var(--mlbb-star)" clip-path="url(#mlbb-half-{{ section.id }})"/>
                </svg>
              {%- endif -%}
            </span>
            <span class="mlbb__rating-text">
              <strong>{{ s.rating }}/5</strong> based on <strong>{{ s.reviews_count }}</strong> reviews
            </span>
          </div>
        {%- endif -%}

        {%- if s.description != blank -%}
          <div class="mlbb__description">{{ s.description }}</div>
        {%- endif -%}

        {%- if s.show_nutritional_button -%}
          <div class="mlbb__nutrition mlbb__nutrition--mobile">
            <button type="button" class="mlbb__nutrition-toggle" @click="nutritionOpen = !nutritionOpen" :aria-expanded="nutritionOpen">
              <svg class="mlbb__nutrition-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="16" x2="12" y2="12"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
              </svg>
              <span>{{ s.nutritional_button_text | default: 'Nutritional Information' }}</span>
            </button>
            <div class="mlbb__nutrition-body" x-show="nutritionOpen" x-collapse>
              {{ s.nutritional_content }}
            </div>
          </div>
        {%- endif -%}

        <div class="mlbb__price">
          <template x-if="compareAtTotal > displayedPrice">
            <span class="mlbb__price-compare" x-text="formatMoney(compareAtTotal)"></span>
          </template>
          <span class="mlbb__price-current" x-text="formatMoney(displayedPrice)"></span>
          <template x-if="savePercent > 0">
            <span class="mlbb__price-save" x-text="'You Save ' + savePercent + '%'"></span>
          </template>
        </div>

        {%- comment -%} ===== QUANTITY (PACK) SELECTOR ===== {%- endcomment -%}
        {%- if pack_blocks.size > 0 -%}
          <div class="mlbb__field">
            <div class="mlbb__field-label">
              <span class="mlbb__field-label-title">QUANTITY:</span>
              <span class="mlbb__field-label-value" x-text="packLabel"></span>
            </div>
            <div class="mlbb__packs">
              {%- for block in pack_blocks -%}
                {%- assign bottle_count = block.settings.bottle_count | default: 1 -%}
                <button
                  type="button"
                  class="mlbb__pack"
                  :class="{ 'is-active': quantity === {{ bottle_count }} }"
                  @click="selectPack({{ bottle_count }})"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.show_best_value -%}
                    <span class="mlbb__pack-best">BEST VALUE</span>
                  {%- endif -%}

                  <div class="mlbb__pack-visual" style="--bottle-count: {{ bottle_count }}">
                    {%- if block.settings.custom_image != blank -%}
                      {%- assign bottle_src = block.settings.custom_image -%}
                    {%- else -%}
                      {%- assign bottle_src = p.featured_image -%}
                    {%- endif -%}
                    {%- if bottle_src != blank -%}
                      {%- for i in (1..bottle_count) -%}
                        {{ bottle_src | image_url: width: 200 | image_tag: loading: 'lazy', class: 'mlbb__pack-bottle', alt: '' }}
                      {%- endfor -%}
                    {%- endif -%}
                  </div>

                  <div class="mlbb__pack-meta">
                    <span class="mlbb__pack-name">{{ block.settings.pack_name }}</span>
                    {%- if block.settings.badge_text != blank -%}
                      <span class="mlbb__pack-badge">{{ block.settings.badge_text }}</span>
                    {%- endif -%}
                  </div>
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        {%- comment -%} ===== FLAVOR PACK DROPDOWNS (visibleFlavorCount, capped by quantity) ===== {%- endcomment -%}
        {%- if p.variants.size > 0 -%}
          <div class="mlbb__flavors">
            <template x-for="(idx, i) in Array.from({length: visibleFlavorCount}, (_, k) => k + 1)" :key="i">
              <div class="mlbb__flavor-row">
                <div class="mlbb__field-label">
                  <span
                    class="mlbb__field-label-title"
                    x-text="visibleFlavorCount === 1 ? 'FLAVOR:' : ('FLAVOR PACK ' + idx + ':')"
                  ></span>
                  <span class="mlbb__field-label-value" x-text="variantTitles[flavorSelections[i] || flavorSelections[0]] || ''"></span>
                </div>
                <div class="mlbb__select-wrap">
                  <select
                    class="mlbb__select"
                    :value="flavorSelections[i] || flavorSelections[0]"
                    @change="setFlavor(i, parseInt($event.target.value))"
                  >
                    {%- for variant in p.variants -%}
                      {%- if variant.available -%}
                        <option value="{{ variant.id }}">{{ variant.title }}</option>
                      {%- endif -%}
                    {%- endfor -%}
                  </select>
                  <svg class="mlbb__chev" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="6 9 12 15 18 9"/>
                  </svg>
                </div>
              </div>
            </template>
          </div>
        {%- endif -%}

        {%- if s.stock_text != blank -%}
          {%- assign stock_hl = s.stock_highlight_text | default: 'In Stock' | strip -%}
          <p class="mlbb__stock">
            <span class="mlbb__stock-dot" aria-hidden="true"></span>
            {%- if stock_hl != blank and s.stock_text contains stock_hl -%}
              {%- assign stock_parts = s.stock_text | split: stock_hl -%}
              <span class="mlbb__stock-text">{{ stock_parts[0] }}<span class="mlbb__stock-highlight">{{ stock_hl }}</span>{{ stock_parts | slice: 1, 99 | join: stock_hl }}</span>
            {%- else -%}
              <span class="mlbb__stock-text">{{ s.stock_text }}</span>
            {%- endif -%}
          </p>
        {%- endif -%}

        <button
          type="button"
          class="mlbb__cta"
          :disabled="loading"
          @click.prevent="addToCart()"
        >
          <span x-show="!loading">{{ s.cta_text | default: 'Start Now →' }}</span>
          <span x-show="loading">Adding…</span>
        </button>

        <p class="mlbb__disclaimer" x-show="isSubscription">
          <span x-text="subscriptionDisclaimer"></span>
        </p>

        <button type="button" class="mlbb__mode-toggle" @click.prevent="addToCart('onetime')" :disabled="loading">
          <span class="mlbb__mode-toggle-label">{{ s.onetime_label | default: 'One-Time Purchase' }} —</span>
          <span class="mlbb__mode-toggle-price" x-text="formatMoney(onetimeTotal)"></span>
          <template x-if="compareAtTotal > onetimeTotal">
            <span class="mlbb__mode-toggle-compare" x-text="formatMoney(compareAtTotal)"></span>
          </template>
        </button>

        {%- if trust_blocks.size > 0 -%}
          <ul class="mlbb__trust">
            {%- for block in trust_blocks -%}
              <li class="mlbb__trust-item" {{ block.shopify_attributes }}>
                <span class="mlbb__trust-icon" style="--trust-bg: {{ block.settings.icon_bg | default: '#D8E4EE' }}">
                  {%- if block.settings.icon != blank -%}
                    {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', class: 'mlbb__trust-icon-img' }}
                  {%- else -%}
                    <svg class="mlbb__trust-placeholder" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M12 2 4 5v6c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5l-8-3z"/>
                    </svg>
                  {%- endif -%}
                </span>
                <span class="mlbb__trust-text">{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- comment -%} ===== ACCORDIONS ===== {%- endcomment -%}
        {%- if accordion_blocks.size > 0 -%}
          <ul class="mlbb__accordions">
            {%- for block in accordion_blocks -%}
              <li class="mlbb__acc" {{ block.shopify_attributes }} x-data="{ open: false }">
                <button type="button" class="mlbb__acc-toggle" @click="open = !open" :aria-expanded="open">
                  <span class="mlbb__acc-title">{{ block.settings.title }}</span>
                  <span class="mlbb__acc-icon" :class="{ 'is-open': open }" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                      <line x1="7" y1="2" x2="7" y2="12"/>
                      <line x1="2" y1="7" x2="12" y2="7"/>
                    </svg>
                  </span>
                </button>
                <div class="mlbb__acc-body" x-show="open" x-collapse>
                  {{ block.settings.body }}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- comment -%} ===== TASTES LIKE ===== {%- endcomment -%}
        {%- if taste_blocks.size > 0 -%}
          <div class="mlbb__tastes">
            {%- if s.tastes_title != blank -%}
              <h3 class="mlbb__tastes-title">{{ s.tastes_title }}</h3>
            {%- endif -%}
            <ul class="mlbb__tastes-list">
              {%- for block in taste_blocks -%}
                <li class="mlbb__taste" {{ block.shopify_attributes }}>
                  <span class="mlbb__taste-img" {% if block.settings.image == blank %}aria-hidden="true"{% endif %}>
                    {%- if block.settings.image != blank -%}
                      {{ block.settings.image | image_url: width: 120 | image_tag: loading: 'lazy', class: 'mlbb__taste-img-tag' }}
                    {%- else -%}
                      <svg class="mlbb__taste-placeholder" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="9"/>
                        <path d="M8 12c1.5-2 6.5-2 8 0"/>
                      </svg>
                    {%- endif -%}
                  </span>
                  <span class="mlbb__taste-label">{{ block.settings.label }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  window.mlbbProductData = window.mlbbProductData || {};
  window.mlbbProductData["{{ section.id }}"] = {
    id: {{ p.id }},
    title: {{ p.title | json }},
    price: {{ p.price | default: 0 }},
    compareAtPrice: {{ p.compare_at_price | default: 0 }},
    variants: [
      {% for variant in p.variants %}
        {
          id: {{ variant.id }},
          title: {{ variant.title | json }},
          price: {{ variant.price | default: 0 }},
          compareAtPrice: {{ variant.compare_at_price | default: 0 }},
          available: {{ variant.available }}
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ],
    variantTitles: {
      {% for variant in p.variants %}{{ variant.id }}: {{ variant.title | json }}{% unless forloop.last %},{% endunless %}{% endfor %}
    }
  };

  window.mlbbPackData = window.mlbbPackData || {};
  window.mlbbPackData["{{ section.id }}"] = [
    {% for block in pack_blocks %}
      {
        bottleCount: {{ block.settings.bottle_count | default: 1 }},
        packName: {{ block.settings.pack_name | json }},
        pricePerUnit: {{ block.settings.price_per_unit | default: 0 }},
        discountMultiplier: parseFloat({{ block.settings.discount_multiplier | default: '1' | json }}) || 1,
        sellingPlanId: {{ block.settings.selling_plan_id | json }},
        frequencyLabel: {{ block.settings.frequency_label | json }},
        isDefault: {{ block.settings.is_default_selected | default: false }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  // Expose the pack -> selling_plan map globally so the shared cart drawer
  // (maison-cart-drawer) can swap the selling_plan when the customer changes
  // quantity via the +/- buttons. The drawer also reads
  // window.frequencyLabelByQuantity for the "Delivery & Payment" line.
  window.sellingPlanByQuantity = window.sellingPlanByQuantity || {};
  window.frequencyLabelByQuantity = window.frequencyLabelByQuantity || {};
  {% for block in pack_blocks %}
    {% if block.settings.selling_plan_id != blank %}
      window.sellingPlanByQuantity[{{ block.settings.bottle_count | default: 1 }}] = {{ block.settings.selling_plan_id | json }};
    {% endif %}
    {% if block.settings.frequency_label != blank %}
      window.frequencyLabelByQuantity[{{ block.settings.bottle_count | default: 1 }}] = {{ block.settings.frequency_label | json }};
    {% endif %}
  {% endfor %}

  window.mlbbConfig = window.mlbbConfig || {};
  window.mlbbConfig["{{ section.id }}"] = {
    subscriptionMultiplier: (function () {
      var pct = {{ s.subscription_discount_percent | default: 15 | json }};
      var num = parseFloat(pct);
      if (!isNaN(num)) return Math.max(0, Math.min(1, 1 - num / 100));
      // Legacy fallback for templates saved with the old multiplier-based setting
      var legacy = parseFloat({{ s.subscription_multiplier | default: '0.85' | json }});
      return isNaN(legacy) ? 0.85 : legacy;
    })(),
    subscriptionDefaultSelected: {{ s.subscription_default_selected | default: true }},
    moneyFormat: {{ shop.money_format | json }},
    onetimeLabel: {{ s.onetime_label | default: 'One-Time Purchase' | json }},
    subscribeLabel: {{ s.subscribe_label | default: 'Subscribe & Save' | json }},
    subscribeDisclaimer: {{ s.subscribe_disclaimer | default: '' | json }},
    discountBucket: {{ s.discount_bucket | default: 'bundle_listicle' | json }},
    singleFlavorForAllPacks: {{ s.single_flavor_for_all_packs | default: true }},
    postAddAction: {{ s.post_add_action | default: 'checkout' | json }}
  };

  function maisonListicleBuyBox() {
    const sectionId = "{{ section.id }}";
    const product = window.mlbbProductData[sectionId];
    const packs = window.mlbbPackData[sectionId];
    const cfg = window.mlbbConfig[sectionId];

    const defaultPack = packs.find(p => p.isDefault) || packs[0] || { bottleCount: 1, discountMultiplier: 1, sellingPlanId: null };
    const defaultVariantId = product.variants[0] ? product.variants[0].id : null;

    return {
      product: product,
      variantTitles: product.variantTitles,
      quantity: defaultPack.bottleCount,
      packLabel: defaultPack.packName || (defaultPack.bottleCount + ' Pack'),
      activeImageIndex: 0,
      nutritionOpen: false,
      isSubscription: cfg.subscriptionDefaultSelected,
      loading: false,
      flavorSelections: Array.from({ length: 6 }, () => defaultVariantId),

      get currentPack() {
        return packs.find(p => p.bottleCount === this.quantity) || packs[0] || defaultPack;
      },

      get unitPriceOnetime() {
        const pack = this.currentPack;
        if (pack && pack.pricePerUnit && pack.pricePerUnit > 0) return pack.pricePerUnit;
        const base = product.price || 0;
        const mult = (pack && pack.discountMultiplier) || 1;
        return Math.round(base * mult);
      },

      get unitPriceSubscribed() {
        return Math.round(this.unitPriceOnetime * cfg.subscriptionMultiplier);
      },

      get comparePerUnit() {
        return product.compareAtPrice && product.compareAtPrice > product.price
          ? product.compareAtPrice
          : product.price;
      },

      get onetimeTotal() { return this.unitPriceOnetime * this.quantity; },
      get subscriptionTotal() { return this.unitPriceSubscribed * this.quantity; },
      get displayedPrice() { return this.isSubscription ? this.subscriptionTotal : this.onetimeTotal; },
      get compareAtTotal() { return this.comparePerUnit * this.quantity; },

      get savePercent() {
        const original = this.compareAtTotal;
        if (original <= 0 || this.displayedPrice >= original) return 0;
        return Math.round((1 - this.displayedPrice / original) * 100);
      },

      get subscribePercent() { return Math.round((1 - cfg.subscriptionMultiplier) * 100); },

      get subscriptionDisclaimer() {
        const pack = this.currentPack;
        // Strip any leading "Ships" / "Delivered" / "Deliver" / "Billed" prefix from the
        // pack's frequency label so the disclaimer reads naturally when concatenated.
        const raw = (pack && pack.frequencyLabel) ? pack.frequencyLabel : 'every 4 weeks';
        const freq = raw.replace(/^\s*(ships?|delivered|deliver|billed)\s+/i, '').trim() || raw;
        const subPrice = this.formatMoney(this.subscriptionTotal);
        const txt = cfg.subscribeDisclaimer;
        if (txt && txt.length > 0) {
          return txt
            .replace('{frequency}', freq)
            .replace('{frequency_raw}', raw)
            .replace('{price}', subPrice);
        }
        return 'Subscription orders billed ' + freq + ' · ' + subPrice + ' + free shipping · Skip or cancel anytime';
      },

      selectPack(bottleCount) {
        this.quantity = bottleCount;
        const pack = packs.find(p => p.bottleCount === bottleCount);
        if (pack) this.packLabel = pack.packName || (bottleCount + ' Pack');
      },

      get visibleFlavorCount() {
        // Checkbox ON → always show a single FLAVOR dropdown (syncs to every pack).
        // Checkbox OFF → show one dropdown per pack (independent picks).
        return cfg.singleFlavorForAllPacks ? 1 : this.quantity;
      },

      setFlavor(index, variantId) {
        if (cfg.singleFlavorForAllPacks) {
          // Sync mode: the single dropdown drives the flavor for every pack.
          this.flavorSelections = this.flavorSelections.map((v, i) =>
            i < this.quantity ? variantId : v
          );
        } else {
          // Independent mode — each visible dropdown only controls its own slot.
          this.flavorSelections = this.flavorSelections.map((v, i) =>
            i === index ? variantId : v
          );
        }
      },

      formatMoney(cents) {
        if (typeof cents !== 'number' || isNaN(cents)) cents = 0;
        if (typeof Shopify !== 'undefined' && typeof Shopify.formatMoney === 'function') {
          return Shopify.formatMoney(cents, cfg.moneyFormat);
        }
        return '$' + (cents / 100).toFixed(2);
      },

      buildCartItems(forceMode) {
        const pack = this.currentPack;
        let useSubscription = this.isSubscription;
        if (forceMode === 'subscribe') useSubscription = true;
        if (forceMode === 'onetime') useSubscription = false;
        const sellingPlan = (useSubscription && pack && pack.sellingPlanId) ? pack.sellingPlanId : null;
        const bucket = cfg.discountBucket || 'bundle_listicle';

        // Build qty -> selling_plan map so the cart drawer can swap the plan
        // when the customer changes quantity later — on ANY page, not just
        // this listicle. Stored as a stringified JSON line-item property so
        // it travels with the cart line.
        const qtyPlans = {};
        packs.forEach(function (p) {
          if (p.sellingPlanId) qtyPlans[p.bottleCount] = p.sellingPlanId;
        });

        const selections = this.flavorSelections.slice(0, this.quantity);
        const grouped = {};
        selections.forEach(variantId => {
          if (!variantId) return;
          grouped[variantId] = (grouped[variantId] || 0) + 1;
        });
        return Object.keys(grouped).map(variantId => {
          const properties = { _mc_discount_bucket: bucket };
          if (Object.keys(qtyPlans).length > 0) {
            properties._qty_plans = JSON.stringify(qtyPlans);
          }
          const item = {
            id: parseInt(variantId),
            quantity: grouped[variantId],
            properties: properties
          };
          if (sellingPlan) item.selling_plan = sellingPlan;
          return item;
        });
      },

      async addToCart(forceMode) {
        if (this.loading) return;
        const items = this.buildCartItems(forceMode);
        if (items.length === 0) return;
        this.loading = true;
        try {
          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ items: items })
          });

          // Always refresh the cart drawer state so it reflects the new line
          // (works regardless of the post-add action below — if the user navigates
          // back from checkout the drawer is already up-to-date).
          if (typeof window.maisonDispatch === 'function') {
            window.maisonDispatch('maison:cart-drawer-reload');
          }
          document.dispatchEvent(new CustomEvent('cart:refresh'));

          const action = cfg.postAddAction || 'checkout';
          if (action === 'cart_drawer') {
            if (typeof window.maisonDispatch === 'function') {
              window.maisonDispatch('maison:cart-drawer-open');
            }
            this.loading = false;
          } else {
            window.location.href = '/checkout';
          }
        } catch (err) {
          console.error('[mlbb] addToCart failed', err);
          this.loading = false;
        }
      }
    };
  }
</script>

