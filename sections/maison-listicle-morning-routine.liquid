<section
  id="shopify-section-{{ section.id }}-morning-routine"
  class="mlmr"
  style="--mlmr-bg: {{ s.bg_color }}; --mlmr-text: {{ s.text_color }}; --mlmr-muted: {{ s.muted_color }}; --mlmr-icon-bg: {{ s.icon_bg }}; --mlmr-icon-color: {{ s.icon_color }}; --mlmr-badge-bg: {{ s.badge_bg }}; --mlmr-badge-text: {{ s.badge_text_color }}; --mlmr-image-radius: {{ s.image_radius }}px;"
>
  <div class="mlmr__container">
    <div class="mlmr__media">
      <div class="mlmr__image-wrap">
        {%- if s.image != blank -%}
          {{ s.image | image_url: width: 1200 | image_tag:
            loading: 'lazy',
            class: 'mlmr__image',
            sizes: '(max-width: 1024px) 100vw, 600px',
            widths: '400, 600, 800, 1200'
          }}
        {%- else -%}
          <div class="mlmr__image mlmr__image--placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if badge_blocks.size > 0 -%}
          <div class="mlmr__badges">
            {%- for block in badge_blocks -%}
              <div class="mlmr__badge" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="mlmr__badge-icon" aria-hidden="true">
                    {{ block.settings.icon | image_url: width: 64 | image_tag: loading: 'lazy', class: 'mlmr__badge-icon-img' }}
                  </span>
                {%- elsif block.settings.emoji != blank -%}
                  <span class="mlmr__badge-icon mlmr__badge-icon--emoji" aria-hidden="true">{{ block.settings.emoji }}</span>
                {%- endif -%}
                <span class="mlmr__badge-text">{{ block.settings.text }}</span>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="mlmr__content">
      <div class="mlmr__head">
        {%- if s.title != blank -%}
          <h2 class="mlmr__title">{{ s.title }}</h2>
        {%- endif -%}
        {%- if s.subtitle != blank -%}
          <p class="mlmr__subtitle">{{ s.subtitle }}</p>
        {%- endif -%}
      </div>

      {%- if feature_blocks.size > 0 -%}
        <ul class="mlmr__features">
          {%- for block in feature_blocks -%}
            {%- assign chosen_icon = block.settings.icon -%}
            <li class="mlmr__feature" {{ block.shopify_attributes }}>
              <div class="mlmr__feature-icon">
                {%- case chosen_icon -%}
                  {%- when 'flash' -%}{{ icon_flash }}
                  {%- when 'target' -%}{{ icon_target }}
                  {%- when 'hand' -%}{{ icon_hand }}
                  {%- else -%}{{ icon_flash }}
                {%- endcase -%}
              </div>
              <div class="mlmr__feature-body">
                {%- if block.settings.title != blank -%}
                  <h3 class="mlmr__feature-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <div class="mlmr__feature-text">{{ block.settings.body }}</div>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .mlmr {
    background: var(--mlmr-bg);
    width: 100%;
    padding: 64px 0;
    display: flex;
    justify-content: center;
    font-family: 'DM Sans', sans-serif;
    color: var(--mlmr-text);
    box-sizing: border-box;
  }
  .mlmr__container {
    width: 100%;
    max-width: 1440px;
    padding: 0 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
    box-sizing: border-box;
  }

  /* Media + image + floating badges */
  .mlmr__media {
    width: 100%;
  }
  .mlmr__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    border-radius: var(--mlmr-image-radius);
    overflow: hidden;
    isolation: isolate;
  }
  .mlmr__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mlmr__image--placeholder {
    background: #D9D9D9;
  }

  .mlmr__badges {
    position: absolute;
    left: 20px;
    right: 20px;
    bottom: 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    z-index: 1;
  }
  .mlmr__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    min-height: 43px;
    padding: 8px 14px;
    background: var(--mlmr-badge-bg);
    color: var(--mlmr-badge-text);
    border-radius: 999px;
    box-sizing: border-box;
    box-shadow: 0 4px 12px rgba(45, 38, 34, 0.08);
  }
  .mlmr__badge-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .mlmr__badge-icon--emoji {
    font-size: 16px;
    line-height: 1;
  }
  .mlmr__badge-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .mlmr__badge-text {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 1.2;
    white-space: nowrap;
  }

  /* Content (heading + features) */
  .mlmr__content {
    display: flex;
    flex-direction: column;
    gap: 40px;
    padding-top: 16px;
  }
  .mlmr__head {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .mlmr__title {
    margin: 0;
    font-family: 'Lust Text', serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.15;
    color: var(--mlmr-text);
    letter-spacing: -0.01em;
  }
  .mlmr__title p {
    margin: 0;
  }
  .mlmr__subtitle {
    margin: 0;
    font-size: 18px;
    line-height: 1.5;
    color: var(--mlmr-muted);
  }

  .mlmr__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .mlmr__feature {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 24px;
    align-items: start;
  }
  .mlmr__feature-icon {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--mlmr-icon-bg);
    color: var(--mlmr-icon-color);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .mlmr__feature-icon svg {
    width: 28px;
    height: 28px;
    display: block;
  }
  .mlmr__feature-body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .mlmr__feature-title {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.35;
    color: var(--mlmr-text);
  }
  .mlmr__feature-text {
    font-size: 16px;
    line-height: 1.5;
    color: var(--mlmr-muted);
  }
  .mlmr__feature-text p {
    margin: 0 0 0.5em 0;
  }
  .mlmr__feature-text p:last-child {
    margin-bottom: 0;
  }

  /* Mobile / cramped desktop */
  @media (max-width: 1024px) {
    .mlmr {
      padding: 40px 0;
    }
    .mlmr__container {
      grid-template-columns: 1fr;
      padding: 0 20px;
      gap: 28px;
    }
    .mlmr__media {
      order: 2;
    }
    .mlmr__content {
      order: 1;
      gap: 28px;
      padding-top: 0;
      text-align: center;
      align-items: center;
    }
    .mlmr__title {
      font-size: 32px;
    }
    .mlmr__subtitle {
      font-size: 16px;
    }
    .mlmr__features {
      gap: 20px;
      width: 100%;
    }
    .mlmr__feature {
      grid-template-columns: 56px 1fr;
      gap: 16px;
      text-align: left;
    }
    .mlmr__feature-icon {
      width: 56px;
      height: 56px;
    }
    .mlmr__feature-icon svg {
      width: 22px;
      height: 22px;
    }
    .mlmr__feature-title {
      font-size: 18px;
    }
    .mlmr__feature-text {
      font-size: 15px;
    }

    .mlmr__badges {
      left: 12px;
      right: 12px;
      bottom: 12px;
      gap: 8px;
    }
    .mlmr__badge {
      min-height: 36px;
      padding: 6px 10px;
    }
    .mlmr__badge-text {
      font-size: 11px;
    }
  }
</style>

{% schema %}
{
  "name": "Listicle Morning Routine",
  "tag": "section",
  "class": "section-maison-listicle-morning-routine",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Background" },
    {
      "type": "color_background",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#3B2B2F" },
    { "type": "color", "id": "muted_color", "label": "Muted text", "default": "#3B2B2FBF" },

    { "type": "header", "content": "Heading" },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Finally, A Morning Routine That Actually Works For You</p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Most people fuel their morning with caffeine and hope. Franky is built differently — every ingredient earns its place."
    },

    { "type": "header", "content": "Image" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_radius",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Image corner radius",
      "default": 16
    },

    { "type": "header", "content": "Image badges (overlay)" },
    { "type": "color", "id": "badge_bg", "label": "Badge background", "default": "#FFFFFF" },
    { "type": "color", "id": "badge_text_color", "label": "Badge text", "default": "#3B2B2F" },

    { "type": "header", "content": "Feature icons" },
    { "type": "color", "id": "icon_bg", "label": "Icon background", "default": "#D8E4EE" },
    { "type": "color", "id": "icon_color", "label": "Icon color", "default": "#3B2B2F" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Image badge",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image (optional)"
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Icon emoji (fallback)",
          "info": "Used if no icon image is uploaded.",
          "default": "💪"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "20g of Protein"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "flash", "label": "Lightning" },
            { "value": "target", "label": "Target / circle" },
            { "value": "hand", "label": "Hand / muscle" }
          ],
          "default": "flash"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Sustained Energy"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Body text.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Listicle Morning Routine",
      "blocks": [
        { "type": "badge", "settings": { "emoji": "💪", "text": "20g of Protein" } },
        { "type": "badge", "settings": { "emoji": "☕", "text": "100% Real Coffee" } },
        { "type": "badge", "settings": { "emoji": "✨", "text": "Prebiotics & L-Theanine" } },
        { "type": "badge", "settings": { "emoji": "🏆", "text": "Top #1 Trending" } },
        {
          "type": "feature",
          "settings": {
            "icon": "flash",
            "title": "Sustained Energy",
            "body": "<p>Real coffee and 20g of protein working together for steady, hours-long energy. No spike on the way up. No crash at 11. No 3pm wall dragging you into the afternoon.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "target",
            "title": "Focus & Mental Clarity",
            "body": "<p>100mg of caffeine paired with 200mg of L-theanine sharpens focus and keeps you locked in — through work, workouts, and everything between.</p>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "hand",
            "title": "20g Protein Per Serving",
            "body": "<p>Complete whey protein aids muscle recovery, curbs hunger, and fuels you without the weight of a heavy shake.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
