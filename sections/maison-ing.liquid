<section
  class="maison_commerce_maison_ing"
  style="
    --mc-ing-bg-start: {{ section.settings.bg_gradient_start }};
    --mc-ing-bg-end: {{ section.settings.bg_gradient_end }};
    --mc-ing-pt-d: {{ section.settings.padding_top_desktop }}px;
    --mc-ing-pb-d: {{ section.settings.padding_bottom_desktop }}px;
    --mc-ing-pl-d: {{ section.settings.padding_left_desktop }}px;
    --mc-ing-pr-d: {{ section.settings.padding_right_desktop }}px;
    --mc-ing-pt-m: {{ section.settings.padding_top_mobile }}px;
    --mc-ing-pb-m: {{ section.settings.padding_bottom_mobile }}px;
    --mc-ing-pl-m: {{ section.settings.padding_left_mobile }}px;
    --mc-ing-pr-m: {{ section.settings.padding_right_mobile }}px;
    --mc-ing-heading-color: {{ section.settings.heading_color }};
    --mc-ing-heading-size-d: {{ section.settings.heading_font_size_desktop }}px;
    --mc-ing-heading-size-m: {{ section.settings.heading_font_size_mobile }}px;
    --mc-ing-subtitle-color: {{ section.settings.subtitle_color }};
    --mc-ing-subtitle-size-d: {{ section.settings.subtitle_font_size_desktop }}px;
    --mc-ing-subtitle-size-m: {{ section.settings.subtitle_font_size_mobile }}px;
    --mc-ing-card-bg: {{ section.settings.card_bg_color }};
    --mc-ing-card-title-color: {{ section.settings.card_title_color }};
    --mc-ing-card-title-size-d: {{ section.settings.card_title_font_size_desktop }}px;
    --mc-ing-card-title-size-m: {{ section.settings.card_title_font_size_mobile }}px;
    --mc-ing-card-desc-color: {{ section.settings.card_desc_color }};
    --mc-ing-card-desc-size-d: {{ section.settings.card_desc_font_size_desktop }}px;
    --mc-ing-card-desc-size-m: {{ section.settings.card_desc_font_size_mobile }}px;
  "
>
  <div class="maison_commerce_maison_ing__container">

    {%- if section.settings.section_heading != blank or section.settings.section_subtitle != blank -%}
      <div class="maison_commerce_maison_ing__header">
        {%- if section.settings.section_heading != blank -%}
          <h2 class="maison_commerce_maison_ing__heading">{{ section.settings.section_heading }}</h2>
        {%- endif -%}
        {%- if section.settings.section_subtitle != blank -%}
          <p class="maison_commerce_maison_ing__subtitle">{{ section.settings.section_subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="maison_commerce_maison_ing__grid">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'ingredient' -%}
            <div class="maison_commerce_maison_ing__card-outer" {{ block.shopify_attributes }}>
              <div class="maison_commerce_maison_ing__card-body">
                <div class="maison_commerce_maison_ing__card-image">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 300
                      | image_tag:
                        alt: block.settings.title,
                        loading: 'lazy',
                        widths: '150, 200, 300'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'maison_commerce_maison_ing__placeholder-svg' }}
                  {%- endif -%}
                </div>
                <div class="maison_commerce_maison_ing__card-txt-wrap">
                  {%- if block.settings.title != blank -%}
                    <h3 class="maison_commerce_maison_ing__card-title">{{ block.settings.title }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="maison_commerce_maison_ing__card-desc">{{ block.settings.description }}</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  /* ============================================
     Section
  ============================================ */
  .maison_commerce_maison_ing {
    box-sizing: border-box;
    width: 100%;
    background: linear-gradient(to bottom, var(--mc-ing-bg-start), var(--mc-ing-bg-end));
    padding: var(--mc-ing-pt-d) var(--mc-ing-pr-d) var(--mc-ing-pb-d) var(--mc-ing-pl-d);
  }

  /* ============================================
     Container
  ============================================ */
  .maison_commerce_maison_ing__container {
    max-width: 1360px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 44px;
  }

  /* ============================================
     Header
  ============================================ */
  .maison_commerce_maison_ing__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    max-width: 651px;
    margin: 0 auto;
    width: 100%;
  }

  .maison_commerce_maison_ing__heading {
    font-family: 'Lust Text', serif;
    font-weight: 400;
    font-style: normal;
    font-size: var(--mc-ing-heading-size-d);
    line-height: 1.2;
    color: var(--mc-ing-heading-color);
    text-transform: capitalize;
    margin: 0;
  }

  .maison_commerce_maison_ing__subtitle {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: var(--mc-ing-subtitle-size-d);
    line-height: 1.5;
    color: var(--mc-ing-subtitle-color);
    opacity: 0.75;
    margin: 0;
  }

  /* ============================================
     Grid — Desktop: horizontal row
  ============================================ */
  .maison_commerce_maison_ing__grid {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: 12px;
    flex-wrap: wrap;
  }

  /* ============================================
     Card outer — Desktop: vertical card
     with image floating above the card body
  ============================================ */
  .maison_commerce_maison_ing__card-outer {
    position: relative;
    display: flex;
    flex: 1;
    width: 100%;
    min-width: 180px;
  }

  /* ============================================
     Card image — Desktop: floats above card body
  ============================================ */
  .maison_commerce_maison_ing__card-image {
    width: 100%;
    max-width: 132px;
    height: auto;
    overflow: hidden;
    margin-left: auto;
  }

  .maison_commerce_maison_ing__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .maison_commerce_maison_ing__card-txt-wrap{
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0px 16px 16px 16px;
  }

  .maison_commerce_maison_ing__placeholder-svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ============================================
     Card body — Desktop
  ============================================ */
  .maison_commerce_maison_ing__card-body {
    background-color: var(--mc-ing-card-bg);
    border: 1px solid rgba(59, 43, 47, 0.18);
    border-radius: 18px;
    min-height: 202px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
  }

  /* ============================================
     Card title
  ============================================ */
  .maison_commerce_maison_ing__card-title {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: var(--mc-ing-card-title-size-d);
    line-height: 1.5;
    color: var(--mc-ing-card-title-color);
  }

  /* ============================================
     Card description
  ============================================ */
  .maison_commerce_maison_ing__card-desc {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    font-size: var(--mc-ing-card-desc-size-d);
    line-height: 1.5;
    color: var(--mc-ing-card-desc-color);
    opacity: 0.75;
    margin: 0;
  }

  /* ============================================
     Mobile
  ============================================ */
  @media (max-width: 768px) {
    /* Section padding */
    .maison_commerce_maison_ing {
      padding: var(--mc-ing-pt-m) var(--mc-ing-pr-m) var(--mc-ing-pb-m) var(--mc-ing-pl-m);
    }

    .maison_commerce_maison_ing__card-txt-wrap{
     padding: 18px 0px 18px 18px;
     max-width: 320px;
     margin-right: 64px;
    }

    /* Container gap */
    .maison_commerce_maison_ing__container {
      gap: 24px;
    }

    /* Header: left-aligned on mobile */
    .maison_commerce_maison_ing__header {
      align-items: center;
      text-align: center;
      margin: 0;
    }

    .maison_commerce_maison_ing__heading {
      font-size: var(--mc-ing-heading-size-m);
    }

    .maison_commerce_maison_ing__subtitle {
      font-size: var(--mc-ing-subtitle-size-m);
    }

    /* Grid: vertical stack */
    .maison_commerce_maison_ing__grid {
      flex-direction: column;
      gap: 8px;
    }

    /* Card outer: horizontal card layout */
    .maison_commerce_maison_ing__card-outer {
      width: 100%;
      padding-top: 0;
      display: flex;
      align-items: stretch;
      background-color: white;
      border: 1px solid rgba(59, 43, 47, 0.18);
      border-radius: 16px;
      overflow: hidden;
    }

    /* Card image: static, on the right */
    .maison_commerce_maison_ing__card-image {
      position: absolute;
      width: 100px;
      height: auto;
      min-height: 75px;
      top: 0;
      right: 0;
      flex-shrink: 0;
      order: 2;
      border-radius: 0;
      overflow: hidden;
    }

    /* Card body: on the left */
    .maison_commerce_maison_ing__card-body {
      flex: 1;
      background: transparent;
      border: none;
      border-radius: 0;
      padding: 0px;
      order: 1;
      min-height: fit-content;
    }

    .maison_commerce_maison_ing__card-title {
      font-size: var(--mc-ing-card-title-size-m);
    }

    .maison_commerce_maison_ing__card-desc {
      font-size: var(--mc-ing-card-desc-size-m);
    }
  }
</style>

{% schema %}
{
