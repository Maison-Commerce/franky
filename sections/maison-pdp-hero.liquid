        <!-- Trust Badges -->
        <div class="xmaison_trust-badges">
          {% for block in section.blocks %}
            {% if block.type == 'trust_badge' %}
              <div class="xmaison_trust-badge" {{ block.shopify_attributes }}>
                {% case block.settings.icon_type %}
                  {% when 'returns' %}
                    {{ trust_icon_returns }}
                  {% when 'shield' %}
                    {{ trust_icon_shield }}
                  {% when 'star_badge' %}
                    {{ trust_icon_star_badge }}
                  {% when 'truck' %}
                    {{ trust_icon_truck }}
                  {% when 'clock' %}
                    {{ trust_icon_clock }}
                  {% when 'guarantee' %}
                    {{ trust_icon_guarantee }}
                {% endcase %}
                <span class="xmaison_trust-text">{{ block.settings.badge_text }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </form>

      <!-- 3rd Party Testing -->
      {% assign test_categories = product.metafields.custom.test_results.value %}
      {% if test_categories != blank and test_categories.size > 0 %}
        {% assign all_passed = true %}
        {% assign total_tests = 0 %}
        {% assign passed_tests = 0 %}
        {% for category in test_categories %}
          {% for entry in category.entries.value %}
            {% assign total_tests = total_tests | plus: 1 %}
            {% if entry.status == 'Passed' %}
              {% assign passed_tests = passed_tests | plus: 1 %}
            {% else %}
              {% assign all_passed = false %}
            {% endif %}
          {% endfor %}
        {% endfor %}

        <div class="xmaison_test-results-trigger" @click="testResultsOpen = true; testResultsActiveTab = 0; document.body.style.overflow = 'hidden'">
          <div class="xmaison_test-results-trigger-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 44 44" fill="none">
              <rect x="0.5" y="0.5" width="43" height="43" rx="21.5" fill="#FBF8F1"/>
              <rect x="0.5" y="0.5" width="43" height="43" rx="21.5" stroke="#FBF8F1"/>
              <path d="M31 16.5957L18.625 28.9707L13 23.3457" stroke="#3B2B2F" stroke-opacity="0.75" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="xmaison_test-results-trigger-content">
            <div class="xmaison_test-results-trigger-top">
              <span class="xmaison_test-results-trigger-title">{{ section.settings.test_results_title }}</span>
              {% if all_passed %}
                <span class="xmaison_test-results-trigger-badge">{{ section.settings.test_results_badge_text }}</span>
              {% endif %}
            </div>
            <div class="xmaison_test-results-trigger-bottom">
              <span class="xmaison_test-results-trigger-desc">{{ section.settings.test_results_description }}</span>
              <span class="xmaison_test-results-trigger-link">{{ section.settings.test_results_link_text }}</span>
