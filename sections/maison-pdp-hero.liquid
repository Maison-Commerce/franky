{{ 'maison-pdp-hero.css' | asset_url | stylesheet_tag }}

<script>
  window.product = {{ product | json }};
  window.defaultPackQuantity = {% assign default_quantity = 1 %}{% assign default_discount = 1 %}{% for block in section.blocks %}{% if block.type == 'pack_option' and block.settings.is_default_selected %}{% assign default_quantity = block.settings.bottle_count %}{% assign default_discount = block.settings.discount_multiplier %}{% endif %}{% endfor %}{{ default_quantity }};
  window.defaultPackDiscount = parseFloat("{{ default_discount }}") || 1;
  window.packPricing = {
    {% for block in section.blocks %}
      {% if block.type == 'pack_option' %}
        {{ block.settings.bottle_count }}: parseFloat("{{ block.settings.discount_multiplier }}") || 1,
      {% endif %}
    {% endfor %}
  };
  window.packNames = {
    {% for block in section.blocks %}
      {% if block.type == 'pack_option' %}
        {{ block.settings.bottle_count }}: "{{ block.settings.pack_name }}",
      {% endif %}
    {% endfor %}
  };
  window.variantTitles = {
    {% for variant in product.variants %}
      {{ variant.id }}: "{{ variant.title | escape }}",
    {% endfor %}
  };
  window.sellingPlanId = {{ section.settings.selling_plan_id | default: 'null' }};
  window.subscriptionMultiplier = parseFloat("{{ section.settings.subscription_multiplier | default: '0.8' }}") || 0.8;
  window.subscriptionDefaultSelected = {% if section.settings.selling_plan_id != blank %}{{ section.settings.subscription_default_selected | default: true }}{% else %}false{% endif %};
  window.sectionMode = "{{ section.settings.section_mode_default | default: 'packs' }}";
  {% if section.settings.section_mode_default == 'classic' %}
    window.defaultPackQuantity = 1;
    window.defaultPackDiscount = 1;
  {% endif %}

  console.log('[Subscription Debug] sellingPlanId:', window.sellingPlanId);
  console.log('[Subscription Debug] subscriptionMultiplier:', window.subscriptionMultiplier);
  console.log('[Subscription Debug] subscriptionDefaultSelected:', window.subscriptionDefaultSelected);
  console.log('[Subscription Debug] selling_plan_id setting raw:', "{{ section.settings.selling_plan_id }}");
</script>

<script>
  function maisonPdpHero() {
    return {
      product: window.product,
      variantId: window.product.variants[0].id,
      quantity: window.defaultPackQuantity || 1,
      currentPackDiscount: window.defaultPackDiscount || 1,
      loading: false,
      packPricing: window.packPricing || {},
      packNames: window.packNames || {},
      isSubscription: window.subscriptionDefaultSelected,
      sellingPlanId: window.sellingPlanId,
      subscriptionMultiplier: window.subscriptionMultiplier,
      variantTitles: window.variantTitles || {},

      init() {
        console.log('[Subscription Debug] Alpine init - isSubscription:', this.isSubscription);
        console.log('[Subscription Debug] Alpine init - sellingPlanId:', this.sellingPlanId);
        console.log('[Subscription Debug] Alpine init - subscriptionMultiplier:', this.subscriptionMultiplier);
        console.log('[Subscription Debug] Alpine init - variantId:', this.variantId);
        console.log('[Subscription Debug] Alpine init - product price:', this.product.price);
        console.log('[Subscription Debug] Alpine init - calculatedPrice:', this.variant?.price || this.product.price);
      },
      nutritionalOpen: false,
      videoModalOpen: false,
      activeVideoId: null,
      bundleAddonSlots: {},

      get variant() {
        return this.product.variants.find((variant) => variant.id === this.variantId);
      },

      get variantTitle() {
        return this.variantTitles[this.variantId] || this.product.title;
      },

      get discountMultiplier() {
        const packDiscount = this.currentPackDiscount || 1;
        return this.isSubscription ? packDiscount * this.subscriptionMultiplier : packDiscount;
      },

      get calculatedPrice() {
        const basePrice = this.variant?.price || this.product.price;
        const packDiscount = this.currentPackDiscount || 1;
        const fullPrice = basePrice * this.quantity;
        const packDiscountedTotal = Math.round(fullPrice * packDiscount);
        if (this.isSubscription) {
          return Math.round(packDiscountedTotal * this.subscriptionMultiplier);
        }
        return packDiscountedTotal;
      },

      get classicDiscountMultiplier() {
        if (this.quantity >= 4) return 0.80;
        if (this.quantity >= 3) return 0.85;
        if (this.quantity >= 2) return 0.90;
        return 1;
      },

      get classicSavePercent() {
        if (this.quantity >= 4) return 20;
        if (this.quantity >= 3) return 15;
        if (this.quantity >= 2) return 10;
        return 0;
      },

      get onetimePrice() {
        if (window.sectionMode === 'bundle') {
          return this.bundleCalculatedPrice;
        }
        if (window.sectionMode === 'classic') {
          const basePrice = this.variant?.price || this.product.price;
          return Math.round(basePrice * this.quantity * this.classicDiscountMultiplier);
        }
        const basePrice = this.variant?.price || this.product.price;
        const packDiscount = this.currentPackDiscount || 1;
        const fullPrice = basePrice * this.quantity;
        return Math.round(fullPrice * packDiscount);
      },

      get bundleAddonTotal() {
        return Object.values(this.bundleAddonSlots).reduce((sum, qty) => sum + (qty || 0), 0);
      },

      get bundleDiscountMultiplier() {
        const total = this.bundleAddonTotal;
        if (total >= 4) return 0.80;
        if (total >= 3) return 0.85;
        if (total >= 2) return 0.90;
        return 1;
      },

      get bundleCalculatedPrice() {
        if (!window.bundleAddonPrices) return 0;
        const rawTotal = Object.entries(this.bundleAddonSlots).reduce((sum, [slotIndex, qty]) => {
          const price = window.bundleAddonPrices[slotIndex] || 0;
          return sum + price * (qty || 0);
        }, 0);
        return Math.round(rawTotal * this.bundleDiscountMultiplier);
      },

      get bundleOriginalPrice() {
        if (!window.bundleAddonPrices) return 0;
        return Object.entries(this.bundleAddonSlots).reduce((sum, [slotIndex, qty]) => {
          const price = window.bundleAddonPrices[slotIndex] || 0;
          return sum + price * (qty || 0);
        }, 0);
      },

      get bundleSavePercent() {
        const total = this.bundleAddonTotal;
        if (total >= 4) return 20;
        if (total >= 3) return 15;
        if (total >= 2) return 10;
        return 0;
      },

      get subscriptionPrice() {
        if (window.sectionMode === 'bundle') {
          return Math.round(this.bundleCalculatedPrice * this.subscriptionMultiplier);
        }
        if (window.sectionMode === 'classic') {
          const basePrice = this.variant?.price || this.product.price;
          return Math.round(basePrice * this.quantity * this.classicDiscountMultiplier * this.subscriptionMultiplier);
        }
        const basePrice = this.variant?.price || this.product.price;
        const packDiscount = this.currentPackDiscount || 1;
        const fullPrice = basePrice * this.quantity;
        const packDiscountedTotal = Math.round(fullPrice * packDiscount);
        return Math.round(packDiscountedTotal * this.subscriptionMultiplier);
      },

      getPackSavings(bottleCount, discountMultiplier) {
        const basePrice = this.variant?.price || this.product.price;
        const fullPrice = basePrice * bottleCount;
        const discountedTotal = Math.round(fullPrice * discountMultiplier);
        return fullPrice - discountedTotal;
      },

      addBundleAddon(slotIndex) {
        this.bundleAddonSlots = { ...this.bundleAddonSlots, [slotIndex]: 1 };
      },

      incrementBundleAddon(slotIndex) {
        const current = this.bundleAddonSlots[slotIndex] || 0;
        this.bundleAddonSlots = { ...this.bundleAddonSlots, [slotIndex]: current + 1 };
      },

      decrementBundleAddon(slotIndex) {
        const current = this.bundleAddonSlots[slotIndex] || 0;
        const next = current - 1;
        this.bundleAddonSlots = { ...this.bundleAddonSlots, [slotIndex]: next < 0 ? 0 : next };
      },

      openVideoModal(videoId) {
        this.activeVideoId = videoId;
        this.videoModalOpen = true;
        document.body.style.overflow = 'hidden';
        this.$nextTick(function() {
          var video = document.querySelector('video.xmaison_popup-video[data-video-id="' + videoId + '"]');
          if (video) {
            video.play();
          }
        });
      },

      closeVideoModal() {
        document.querySelectorAll('.xmaison_popup-video').forEach(function(v) {
          v.pause();
          v.currentTime = 0;
        });
        // Reset play/pause button states
        document.querySelectorAll('.xmaison_modal-play-btn--play').forEach(function(btn) {
          btn.style.display = 'flex';
        });
        document.querySelectorAll('.xmaison_video-container').forEach(function(c) {
          c.classList.remove('is-playing');
        });
        this.videoModalOpen = false;
        this.activeVideoId = null;
        document.body.style.overflow = '';
      },

      formatMoney(cents) {
        if (window.Shopify?.formatMoney) {
          return Shopify.formatMoney(cents);
        }
        const currency = Shopify?.currency?.active || 'USD';
        return (cents / 100).toLocaleString('en-US', {
          style: 'currency',
          currency: currency,
        });
      },

      addToCart(variantId = null, qty = null) {
        if (this.loading) return;
        this.loading = true;

        const isRelated = variantId !== null;
        const hasBundleAddons = !isRelated && this.bundleAddonTotal > 0;
        const bundleId = hasBundleAddons ? 'bundle_true' : null;

        console.log('[AddToCart Debug] isRelated:', isRelated);
        console.log('[AddToCart Debug] hasBundleAddons:', hasBundleAddons);
        console.log('[AddToCart Debug] isSubscription:', this.isSubscription);
        console.log('[AddToCart Debug] sellingPlanId:', this.sellingPlanId);
        console.log('[AddToCart Debug] variantId:', variantId || this.variantId);
        console.log('[AddToCart Debug] quantity:', qty || this.quantity);

        const mainItem = {
          id: variantId || this.variantId,
          quantity: hasBundleAddons ? 1 : (qty || this.quantity),
        };

        if (this.isSubscription && this.sellingPlanId && !isRelated) {
          mainItem.selling_plan = this.sellingPlanId;
        }

        if (hasBundleAddons) {
          mainItem.properties = { mc_bundle: bundleId };
        } else if (!isRelated && window.sectionMode !== 'classic') {
          mainItem.properties = { mc_packs: 'packs_true' };
        }

        console.log('[AddToCart Debug] mainItem:', JSON.stringify(mainItem));

        let payload;
        if (hasBundleAddons) {
          const items = [];
          if (window.bundleAddonVariants) {
            Object.entries(this.bundleAddonSlots).forEach(([slotIndex, qty]) => {
              if (qty > 0) {
                const addonVariantId = window.bundleAddonVariants[slotIndex];
                if (addonVariantId) {
                  const item = {
                    id: addonVariantId,
                    quantity: qty,
                    properties: { mc_bundle: bundleId },
                  };
                  if (this.isSubscription && this.sellingPlanId) {
                    item.selling_plan = this.sellingPlanId;
                  }
                  items.push(item);
                }
              }
            });
          }
          payload = { items };
        } else {
          payload = mainItem;
        }

        console.log('[AddToCart Debug] final payload:', JSON.stringify(payload));

        fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        })
          .then((res) => {
            console.log('[AddToCart Debug] response status:', res.status);
            return res.json();
          })
          .then((data) => {
            console.log('[AddToCart Debug] response data:', JSON.stringify(data));
            maisonDispatch('maison:cart-drawer-reload');
            maisonDispatch('maison:cart-drawer-open');
          })
          .catch((err) => {
            console.error('[AddToCart Debug] error:', err);
          })
          .finally(() => {
            this.loading = false;
          });
      },
    };
  }
</script>

