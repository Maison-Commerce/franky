<section x-data="maisonPdpHero()" class="xmaison_product-section">
  <div class="xmaison_product-container">
    <!-- Product Title & Rating (Mobile: shows first) -->
    <div class="xmaison_product-header-top">
      <h1 class="xmaison_product-title">{{ product.title }}</h1>
      {%- liquid
        assign pdp_has_reviews = false
        assign pdp_rating_raw = 0
        assign pdp_review_count = 0

        if product.metafields.reviews.rating.value != blank
          assign pdp_rating_raw = product.metafields.reviews.rating.value.rating | times: 1.0
          assign pdp_has_reviews = true
        elsif product.metafields.custom.rating != blank
          assign pdp_rating_raw = product.metafields.custom.rating | times: 1.0
          assign pdp_has_reviews = true
        endif

        if product.metafields.reviews.rating_count != blank
          assign pdp_review_count = product.metafields.reviews.rating_count
          assign pdp_has_reviews = true
        elsif product.metafields.custom.review_count != blank
          assign pdp_review_count = product.metafields.custom.review_count
          assign pdp_has_reviews = true
        endif

        if pdp_review_count == 0 or pdp_review_count == blank
          if product.metafields.custom.mc_stars != blank and product.metafields.custom.mc_reviews_count != blank and product.metafields.custom.mc_reviews_count > 0
            assign pdp_mc_stars_str = product.metafields.custom.mc_stars | replace: ',', '.'
            assign pdp_rating_raw = pdp_mc_stars_str | times: 1.0
            assign pdp_review_count = product.metafields.custom.mc_reviews_count
            assign pdp_has_reviews = true
          endif
        endif

        if pdp_has_reviews == false
          if section.settings.rating_score != blank and section.settings.rating_count != blank
            assign pdp_has_reviews = true
          endif
        endif

        assign pdp_filled_stars = pdp_rating_raw | floor
        assign pdp_rating_remainder = pdp_rating_raw | minus: pdp_filled_stars
        assign pdp_has_half_star = false
        if pdp_rating_remainder > 0
          assign pdp_has_half_star = true
        endif
        assign pdp_half_star_position = pdp_filled_stars | plus: 1
      -%}
      {% if pdp_has_reviews %}
      <div class="xmaison_rating-badge">
        <div class="xmaison_stars">
          {% if pdp_rating_raw > 0 %}
            {% for i in (1..5) %}
              {% if i <= pdp_filled_stars %}
                <svg class="xmaison_star" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 1.33l1.79 3.62 4 .58-2.9 2.82.68 3.98L8 10.42l-3.57 1.88.68-3.98-2.9-2.82 4-.58L8 1.33z" fill="#FF8C00" stroke="#FF8C00" stroke-width="1"/>
                </svg>
              {% elsif pdp_has_half_star and i == pdp_half_star_position %}
                <svg class="xmaison_star" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <defs>
                    <clipPath id="pdpHalfStar-{{ product.id }}-{{ i }}">
                      <rect x="0" y="0" width="8" height="16"/>
                    </clipPath>
                  </defs>
                  <path d="M8 1.33l1.79 3.62 4 .58-2.9 2.82.68 3.98L8 10.42l-3.57 1.88.68-3.98-2.9-2.82 4-.58L8 1.33z" fill="none" stroke="#E0E0E0" stroke-width="1"/>
                  <path clip-path="url(#pdpHalfStar-{{ product.id }}-{{ i }})" d="M8 1.33l1.79 3.62 4 .58-2.9 2.82.68 3.98L8 10.42l-3.57 1.88.68-3.98-2.9-2.82 4-.58L8 1.33z" fill="#FF8C00" stroke="#FF8C00" stroke-width="1"/>
                </svg>
              {% else %}
                <svg class="xmaison_star" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M8 1.33l1.79 3.62 4 .58-2.9 2.82.68 3.98L8 10.42l-3.57 1.88.68-3.98-2.9-2.82 4-.58L8 1.33z" fill="none" stroke="#E0E0E0" stroke-width="1"/>
                </svg>
              {% endif %}
            {% endfor %}
          {% else %}
            {% for i in (1..5) %}
              <svg class="xmaison_star" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M8 1.33l1.79 3.62 4 .58-2.9 2.82.68 3.98L8 10.42l-3.57 1.88.68-3.98-2.9-2.82 4-.58L8 1.33z" fill="#FF8C00" stroke="#FF8C00" stroke-width="1"/>
              </svg>
            {% endfor %}
          {% endif %}
        </div>
        <span class="xmaison_rating-text">
          {% if pdp_rating_raw > 0 %}
            Rated <strong>{{ pdp_rating_raw }}</strong>/5 based on
            <strong>{{ pdp_review_count }}</strong> reviews.
          {% else %}
            Rated <strong>{{ section.settings.rating_score }}</strong> based on
            <strong>{{ section.settings.rating_count }}</strong> reviews.
          {% endif %}
        </span>
      </div>
      {% endif %}
    </div>

    <!-- Product Gallery (Mobile: shows second) -->
    <div class="xmaison_product-gallery">
      <div class="xmaison_gallery-wrapper">
        <!-- Main Image Swiper -->
        <div class="xmaison_gallery-main swiper" id="galleryMain">
          <div class="swiper-wrapper">
            {% for image in product.images %}
              <div class="swiper-slide">
                <img src="{{ image | image_url: width: 600 }}" alt="{{ product.title }}">
              </div>
            {% endfor %}
          </div>
          {% if section.settings.natural_badge_image %}
            <div class="xmaison_badge-natural">
                <img
                  src="{{ section.settings.natural_badge_image | image_url: width: 120 }}"
                  alt="{{ section.settings.natural_badge_alt }}"
                >
            </div>
          {% endif %}
        </div>
        <!-- Thumbnails Swiper -->
        <div class="xmaison_gallery-thumbnails swiper" id="galleryThumbs">
          <div class="swiper-wrapper">
            {% for image in product.images %}
              <div class="swiper-slide xmaison_thumbnail">
                <img src="{{ image | image_url: width: 80 }}" alt="{{ product.title }}">
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <!-- Nutritional Information Button -->
      {% for block in section.blocks %}
        {% if block.type == 'nutritional_info' %}
          <div class="xmaison_nutritional-btn-wrapper" {{ block.shopify_attributes }}>
            <button
              type="button"
              class="xmaison_nutritional-btn"
              @click="nutritionalOpen = true; document.body.style.overflow = 'hidden'"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M9 16.5C4.85775 16.5 1.5 13.1423 1.5 9C1.5 4.85775 4.85775 1.5 9 1.5C13.1423 1.5 16.5 4.85775 16.5 9C16.5 13.1423 13.1423 16.5 9 16.5ZM9 15C10.5913 15 12.1174 14.3679 13.2426 13.2426C14.3679 12.1174 15 10.5913 15 9C15 7.4087 14.3679 5.88258 13.2426 4.75736C12.1174 3.63214 10.5913 3 9 3C7.4087 3 5.88258 3.63214 4.75736 4.75736C3.63214 5.88258 3 7.4087 3 9C3 10.5913 3.63214 12.1174 4.75736 13.2426C5.88258 14.3679 7.4087 15 9 15ZM9 7.5C9.19891 7.5 9.38968 7.57902 9.53033 7.71967C9.67098 7.86032 9.75 8.05109 9.75 8.25V12C9.75 12.1989 9.67098 12.3897 9.53033 12.5303C9.38968 12.671 9.19891 12.75 9 12.75C8.80109 12.75 8.61032 12.671 8.46967 12.5303C8.32902 12.3897 8.25 12.1989 8.25 12V8.25C8.25 8.05109 8.32902 7.86032 8.46967 7.71967C8.61032 7.57902 8.80109 7.5 9 7.5ZM9 6.75C8.80109 6.75 8.61032 6.67098 8.46967 6.53033C8.32902 6.38968 8.25 6.19891 8.25 6C8.25 5.80109 8.32902 5.61032 8.46967 5.46967C8.61032 5.32902 8.80109 5.25 9 5.25C9.19891 5.25 9.38968 5.32902 9.53033 5.46967C9.67098 5.61032 9.75 5.80109 9.75 6C9.75 6.19891 9.67098 6.38968 9.53033 6.53033C9.38968 6.67098 9.19891 6.75 9 6.75Z" fill="#3B2B2F"/>
              </svg>
              <span class="xmaison_nutritional-btn-text">{{ block.settings.button_text }}</span>
            </button>
          </div>

          <!-- Nutritional Info Popup -->
          <div
            class="xmaison_nutritional-overlay"
            x-show="nutritionalOpen"
            x-transition.opacity
            @click.self="nutritionalOpen = false; document.body.style.overflow = ''"
            x-cloak
          >
            <div class="xmaison_nutritional-popup">
              <div class="xmaison_nutritional-popup-header">
                <h3 class="xmaison_nutritional-popup-title">{{ block.settings.button_text }}</h3>
                <button
                  type="button"
                  class="xmaison_nutritional-popup-close"
                  @click="nutritionalOpen = false; document.body.style.overflow = ''"
                >
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M18 6L6 18M6 6l12 12" stroke="#3B2B2F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
              </div>
              <div class="xmaison_nutritional-popup-body">
                {{ block.settings.popup_content }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      <!-- Gallery Navigation Buttons -->
      <div class="xmaison_gallery-nav">
        <button class="xmaison_gallery-nav-btn xmaison_gallery-prev" aria-label="Previous image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18L9 12L15 6" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button class="xmaison_gallery-nav-btn xmaison_gallery-next" aria-label="Next image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M9 18L15 12L9 6" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Product Info (Mobile: shows third) -->
    <div class="xmaison_product-info">
      <!-- Product Description & Features -->
      {% if product.description != blank %}
        <div class="xmaison_product-header">
          <div class="xmaison_product-description">
            {{ product.description }}
          </div>
          {% comment %} <div class="xmaison_feature-list">
            {% for block in section.blocks %}
              {% if block.type == 'feature_item' %}
                <div class="xmaison_feature-item" {{ block.shopify_attributes }}>
                  {% case block.settings.icon_type %}
                    {% when 'checkmark' %}
                      {{ feature_icon_checkmark }}
                    {% when 'star' %}
                      {{ feature_icon_star }}
                    {% when 'heart' %}
                      {{ feature_icon_heart }}
                    {% when 'lightning' %}
                      {{ feature_icon_lightning }}
                    {% when 'leaf' %}
                      {{ feature_icon_leaf }}
                  {% endcase %}
                  <span class="xmaison_feature-text"
                    ><strong>{{ block.settings.feature_text_bold }}</strong> {{ block.settings.feature_text_regular -}}
                  </span>
                </div>
              {% endif %}
            {% endfor %}
          </div> {% endcomment %}
        </div>
      {% endif %}

      <!-- Product Options -->
      <div class="xmaison_product-options">
        <!-- Price Display -->
        <div class="xmaison_pdp-price">
          <span class="xmaison_pdp-price-current" x-text="formatMoney(isPreorder ? preorderPrice : (isSubscription ? subscriptionPrice : onetimePrice))"></span>
          {% if section.settings.preorder_enabled %}
            <span class="xmaison_pdp-price-compare" x-show="isPreorder" x-text="formatMoney(preorderOriginalPrice)"></span>
            <span class="xmaison_pdp-price-save" x-show="isPreorder" x-text="'YOU SAVE ' + {{ settings.preorder_discount_percent | default: 15 }} + '%'"></span>
          {% endif %}
          {% if section.settings.section_mode_default == 'bundle' %}
            <span class="xmaison_pdp-price-compare" x-show="!isPreorder && bundleAddonTotal >= 2 && bundleOriginalPrice > bundleCalculatedPrice" x-text="formatMoney(bundleOriginalPrice)"></span>
            <span class="xmaison_pdp-price-save" x-show="!isPreorder && bundleAddonTotal >= 2 && bundleSavePercent > 0" x-text="'YOU SAVE ' + bundleSavePercent + '%'"></span>
          {% else %}
            <span class="xmaison_pdp-price-compare" x-show="!isPreorder && variant && variant.compare_at_price && variant.compare_at_price > variant.price" x-text="formatMoney(variant?.compare_at_price * quantity)"></span>
            <span class="xmaison_pdp-price-save" x-show="!isPreorder && variant && variant.compare_at_price && variant.compare_at_price > variant.price && (isSubscription ? subscriptionPrice : onetimePrice) > 0" x-text="'YOU SAVE ' + Math.round((1 - (isSubscription ? subscriptionPrice : onetimePrice) / (variant?.compare_at_price * quantity)) * 100) + '%'"></span>
          {% endif %}
        </div>

        <!-- Variant Selector -->
        {% unless section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' or section.settings.section_mode_default == 'classic' %}
          {% if product.variants.size > 0 %}
            <div class="xmaison_option-group">
              <div class="xmaison_option-label">
                <span class="xmaison_option-label-title">{{ product.options.first }}:</span>
                <span class="xmaison_option-label-value" x-text="variantTitles[variantId] || ''"></span>
              </div>
              <div class="xmaison_flavor-select-wrapper">
                <select class="xmaison_flavor-select" :value="variantId" @change="variantId = parseInt($event.target.value)">
                  {% for variant in product.variants %}
                    <option value="{{ variant.id }}"{% if variant == product.selected_or_first_available_variant %} selected{% endif %}>
                      {{ variant.title }}
                    </option>
                  {% endfor %}
                </select>
                <svg class="xmaison_chevron-down" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M6 9l6 6 6-6" stroke="#475467" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </div>
          {% endif %}
        {% endunless %}

        <!-- Classic Quantity Selector -->
        {% if section.settings.section_mode_default == 'classic' %}
          <div class="xmaison_classic-quantity-group">
            <div class="xmaison_option-label">
              <span class="xmaison_option-label-title">Quantity:</span>
            </div>
            <div class="xmaison_classic-quantity">
              <button type="button" class="xmaison_qty-btn xmaison_qty-minus" @click="if (quantity > 1) quantity--" :disabled="quantity <= 1">
                <svg width="14" height="2" viewBox="0 0 14 2" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 1H13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
              <input
                type="number"
                class="xmaison_qty-input"
                :value="quantity"
                @change="quantity = Math.max(1, parseInt($event.target.value) || 1)"
                min="1"
              >
              <button type="button" class="xmaison_qty-btn xmaison_qty-plus" @click="quantity++">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M1 7H13M7 1V13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </button>
            </div>
          </div>
        {% endif %}

        <!-- Pack Size Selector -->
        {% unless section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' or section.settings.section_mode_default == 'classic' %}
        {% if section.settings.pack_size_label != blank %}
          <div class="xmaison_pack-size-group">
            <div class="xmaison_option-label">
              <span class="xmaison_option-label-title">Quantity:</span>
              <span class="xmaison_option-label-value" x-text="packNames[quantity] || '{{ section.settings.pack_size_label }}'"></span>
            </div>
            <div class="xmaison_pack-options">
              {% for block in section.blocks %}
                {% if block.type == 'pack_option' %}
                  <div
                    class="xmaison_pack-option"
                    :class="{ 'xmaison_selected': quantity === {{ block.settings.bottle_count }} }"
                    @click="quantity = {{ block.settings.bottle_count }}; currentPackDiscount = {{ block.settings.discount_multiplier | default: 1 }}"
                    {{ block.shopify_attributes }}
                  >
                    <div class="xmaison_pack-images">
                      {% for i in (1..block.settings.bottle_count) %}
                        <img
                          class="xmaison_pack-image"
                          src="{{ block.settings.custom_image | default: product.featured_image | image_url: width: 100 }}"
                          alt="{{ block.settings.pack_name }}"
                        >
                      {% endfor %}
                    </div>
                    <div class="xmaison_pack-details">
                      <span class="xmaison_pack-name">{{ block.settings.pack_name }}</span>
                      {% assign discount_multiplier = block.settings.discount_multiplier | times: 1.0 %}
                      {% if discount_multiplier < 1 %}
                        {% assign discount_percent = 1 | minus: discount_multiplier | times: 100 | round %}
                        <div class="xmaison_pack-badge">
                          {% if section.settings.preorder_enabled %}
                            {% assign preorder_discount = settings.preorder_discount_percent | default: 15 %}
                            {% assign combined_percent = discount_percent | plus: preorder_discount %}
                            <span class="xmaison_pack-badge-text" x-text="isPreorder ? 'Save {{ combined_percent }}%' : 'Save {{ discount_percent }}%'">Save {{ discount_percent }}%</span>
                          {% else %}
                            <span class="xmaison_pack-badge-text">Save {{ discount_percent }}%</span>
                          {% endif %}
                        </div>
                      {% elsif section.settings.preorder_enabled %}
                        <div class="xmaison_pack-badge" x-show="isPreorder" x-cloak>
                          <span class="xmaison_pack-badge-text">Save {{ settings.preorder_discount_percent | default: 15 }}%</span>
                        </div>
                      {% endif %}
                    </div>
                    {% if block.settings.show_best_value %}
                      <div class="xmaison_best-value-badge">
                        <span class="xmaison_best-value-text">{{ block.settings.badge_text }}</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
        {% endunless %}

        <!-- Build Your Bundle -->
        {% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %}
          <div class="xmaison_bundle-section">
            <span class="xmaison_bundle-title">{{ section.settings.bundle_title }}</span>

            <!-- Progress Bar -->
            <div class="xmaison_bundle-progress">
              <div class="xmaison_bundle-step" :class="{ 'xmaison_bundle-step--active': bundleAddonTotal >= 1 }">
                <span class="xmaison_bundle-tier-qty">{{ section.settings.bundle_tier1_label }}</span>
                <div class="xmaison_bundle-dot"></div>
                <span class="xmaison_bundle-tier-price">{{ section.settings.bundle_tier1_price }}</span>
              </div>
              <div class="xmaison_bundle-connector" :class="{ 'xmaison_bundle-connector--active': bundleAddonTotal >= 2 }"></div>
              <div class="xmaison_bundle-step" :class="{ 'xmaison_bundle-step--active': bundleAddonTotal >= 2 }">
                <span class="xmaison_bundle-tier-qty">{{ section.settings.bundle_tier2_label }}</span>
                <div class="xmaison_bundle-dot"></div>
                <span class="xmaison_bundle-tier-price">{{ section.settings.bundle_tier2_price }}</span>
              </div>
              <div class="xmaison_bundle-connector" :class="{ 'xmaison_bundle-connector--active': bundleAddonTotal >= 3 }"></div>
              <div class="xmaison_bundle-step" :class="{ 'xmaison_bundle-step--active': bundleAddonTotal >= 3 }">
                <span class="xmaison_bundle-tier-qty">{{ section.settings.bundle_tier3_label }}</span>
                <div class="xmaison_bundle-dot"></div>
                <span class="xmaison_bundle-tier-price">{{ section.settings.bundle_tier3_price }}</span>
              </div>
              <div class="xmaison_bundle-connector" :class="{ 'xmaison_bundle-connector--active': bundleAddonTotal >= 4 }"></div>
              <div class="xmaison_bundle-step" :class="{ 'xmaison_bundle-step--active': bundleAddonTotal >= 4 }">
                <span class="xmaison_bundle-tier-qty">{{ section.settings.bundle_tier4_label }}</span>
                <div class="xmaison_bundle-dot"></div>
                <span class="xmaison_bundle-tier-price">{{ section.settings.bundle_tier4_price }}</span>
              </div>
            </div>

            <!-- Add-on Product Slots -->
            {%- assign has_bundle_blocks = false -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'bundle_product' -%}
                {%- assign has_bundle_blocks = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}

            {% if has_bundle_blocks %}
              <script>
                window.bundleAddonVariants = {
                  {%- assign bundle_index = 0 -%}
                  {% for block in section.blocks %}
                    {% if block.type == 'bundle_product' and block.settings.product != blank %}
                      {%- assign bundle_index = bundle_index | plus: 1 -%}
                      {{ bundle_index }}: {{ block.settings.product.variants.first.id }},
                    {% endif %}
                  {% endfor %}
                };
                window.bundleAddonPrices = {
                  {%- assign bundle_index = 0 -%}
                  {% for block in section.blocks %}
                    {% if block.type == 'bundle_product' and block.settings.product != blank %}
                      {%- assign bundle_index = bundle_index | plus: 1 -%}
                      {{ bundle_index }}: {{ block.settings.product.variants.first.price }},
                    {% endif %}
                  {% endfor %}
                };
              </script>
              <div class="xmaison_bundle-addons">
                {%- assign slot_index = 0 -%}
                {% for block in section.blocks %}
                  {% if block.type == 'bundle_product' and block.settings.product != blank %}
                    {%- assign slot_index = slot_index | plus: 1 -%}
                    {%- assign bundle_product = block.settings.product -%}
                    <div
                      class="xmaison_bundle-addon"
                      :class="{ 'xmaison_bundle-addon--added': bundleAddonSlots[{{ slot_index }}] > 0 }"
                      {{ block.shopify_attributes }}
                    >
                      <div class="xmaison_bundle-addon-image">
                        {% if block.settings.custom_image != blank %}
                          <img
                            src="{{ block.settings.custom_image | image_url: width: 170 }}"
                            alt="{{ bundle_product.title }}"
                            loading="lazy"
                          >
                        {% elsif bundle_product.featured_image %}
                          <img
                            src="{{ bundle_product.featured_image | image_url: width: 170 }}"
                            alt="{{ bundle_product.title }}"
                            loading="lazy"
                          >
                        {% endif %}
                      </div>
                      <div class="xmaison_bundle-addon-details">
                        <span class="xmaison_bundle-addon-title">{{ bundle_product.title }}</span>
                        {% if bundle_product.description != blank %}
                          <p class="xmaison_bundle-addon-desc">{{ bundle_product.description | strip_html | truncate: 80 }}</p>
                        {% endif %}
                      </div>
                      <div class="xmaison_bundle-addon-actions">
                        <button
                          class="xmaison_bundle-addon-btn"
                          type="button"
                          @click="addBundleAddon({{ slot_index }})"
                          x-show="!(bundleAddonSlots[{{ slot_index }}] > 0)"
                        >Add</button>
                        <div
                          class="xmaison_bundle-qty-picker"
                          x-show="bundleAddonSlots[{{ slot_index }}] > 0"
                        >
                          <button class="xmaison_bundle-qty-btn" type="button" @click="decrementBundleAddon({{ slot_index }})">-</button>
                          <span class="xmaison_bundle-qty-value" x-text="bundleAddonSlots[{{ slot_index }}] || 0"></span>
                          <button class="xmaison_bundle-qty-btn" type="button" @click="incrementBundleAddon({{ slot_index }})">+</button>
                        </div>
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endif %}

        <!-- Subscription Options -->
        {% if section.settings.selling_plan_id != blank %}
          <div class="xmaison_subscription-group">
            <span class="xmaison_subscription-label">{{ section.settings.subscription_header_label }}</span>
            <div class="xmaison_subscription-options">
              <!-- Subscribe & Save Option -->
              <div
                class="xmaison_subscription-option xmaison_subscribe"
                :class="{ 'xmaison_selected': isSubscription }"
                @click="isSubscription = true"
              >
                <div class="xmaison_subscription-content">
                  <div class="xmaison_subscription-header">
                    <div class="xmaison_subscription-title-row">
                      <span class="xmaison_subscription-title">{{ section.settings.subscribe_title }}</span>
                      <div class="xmaison_save-badge">
                        {% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %}
                          <span class="xmaison_save-badge-text" x-text="bundleSavePercent > 0 ? 'SAVE ' + Math.round((1 - (bundleCalculatedPrice / bundleOriginalPrice) * subscriptionMultiplier) * 100) + '%' : '{{ section.settings.subscribe_save_badge }}'"></span>
                        {% else %}
                          <span class="xmaison_save-badge-text">{{ section.settings.subscribe_save_badge }}</span>
                        {% endif %}
                      </div>
                    </div>
                    <div class="xmaison_price-row">
                      <span class="xmaison_price-current" x-text="formatMoney(subscriptionPrice)"></span>
                      {% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %}
                        <span class="xmaison_price-original" x-text="formatMoney(bundleOriginalPrice)"></span>
                      {% else %}
                        <span class="xmaison_price-original" x-text="formatMoney(onetimePrice)"></span>
                      {% endif %}
                    </div>
                  </div>
                  <div class="xmaison_subscription-divider"></div>
                  <div class="xmaison_subscription-benefits">
                    {% for block in section.blocks %}
                      {% if block.type == 'subscription_benefit' %}
                        <div class="xmaison_benefit-item" {{ block.shopify_attributes }}>
                          {% case block.settings.icon_type %}
                            {% when 'checkmark' %}
                              {{ benefit_icon_checkmark }}
                            {% when 'star' %}
                              {{ benefit_icon_star }}
                            {% when 'gift' %}
                              {{ benefit_icon_gift }}
                            {% when 'truck' %}
                              {{ benefit_icon_truck }}
                            {% when 'percent' %}
                              {{ benefit_icon_percent }}
                          {% endcase %}
                          <span class="xmaison_benefit-text">{{ block.settings.benefit_text }}</span>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
                <div class="xmaison_most-popular-tag">
                  <span class="xmaison_most-popular-text">{{ section.settings.subscribe_popular_tag }}</span>
                </div>
              </div>

              <!-- One-time Purchase -->
              <div
                class="xmaison_subscription-option xmaison_onetime"
                :class="{ 'xmaison_selected': !isSubscription }"
                @click="isSubscription = false"
              >
                <span class="xmaison_subscription-title">{{ section.settings.onetime_title }}</span>
                <div class="xmaison_price-row">
                  <span class="xmaison_price-current" x-text="formatMoney(onetimePrice)"></span>
                  {% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %}
                    <span class="xmaison_price-original" x-show="bundleSavePercent > 0" x-text="formatMoney(bundleOriginalPrice)"></span>
                    <span class="xmaison_save-badge xmaison_save-badge--onetime" x-show="bundleSavePercent > 0">
                      <span class="xmaison_save-badge-text" x-text="'SAVE ' + bundleSavePercent + '%'"></span>
                    </span>
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      </div>

      <!-- Add to Cart Section -->
      <form
        action="{{ routes.cart_add_url }}"
        method="post"
        class="xmaison_add-to-cart-section"
        @submit.prevent="addToCart()"
      >
        <input type="hidden" name="id" :value="variantId">
        <input type="hidden" name="quantity" :value="quantity">

        <div class="xmaison_stock-status">
          <span class="xmaison_stock-dot"></span>
          <span class="xmaison_stock-text">
            <span class="xmaison_in-stock">{{ section.settings.stock_status_text }}</span> -
            {{ section.settings.shipping_text }}
          </span>
        </div>

        <button type="submit" class="xmaison_add-to-cart-button" :disabled="loading{% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %} || bundleAddonTotal === 0{% endif %}" {% if section.settings.preorder_enabled %}x-show="!isPreorder"{% endif %}>
          <span class="xmaison_add-to-cart-text">{{ section.settings.add_to_cart_text }}</span>
        </button>

        <!-- Pre-Order Button -->
        {% if section.settings.preorder_enabled %}
          <div class="xmaison_preorder-section" x-show="isPreorder" x-cloak>
            <button
              type="button"
              class="xmaison_preorder-button"
              :disabled="loading{% if section.settings.bundle_enabled and section.settings.section_mode_default == 'bundle' %} || bundleAddonTotal === 0{% endif %}"
              @click="addToCartPreOrder()"
            >
              <div class="xmaison_preorder-button-top">
                <span class="xmaison_preorder-text">{{ section.settings.preorder_button_text }}</span>
                <span class="xmaison_preorder-dot"></span>
                <span class="xmaison_preorder-price-current" x-text="formatMoney(preorderPrice)"></span>
                <span class="xmaison_preorder-price-original" x-text="formatMoney(preorderOriginalPrice)"></span>
              </div>
              <span class="xmaison_preorder-note" x-text="preorderPropertyValue"></span>
            </button>
          </div>
        {% endif %}

        <!-- Payment Methods -->
        <div class="xmaison_payment-methods">
          <svg xmlns="http://www.w3.org/2000/svg" width="29" height="20" viewBox="0 0 29 20" fill="none">
            <rect x="0.40253" y="0.40253" width="27.372" height="18.5164" rx="2.81771" fill="white" stroke="#D0D5DD" stroke-width="0.805059"/>
